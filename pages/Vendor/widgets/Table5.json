  "searchKey": "",
  "tableData": "{{ \n  // Replace 'your_invoice_query_name' with your actual invoice API/Query name\n  fetch_invoices_api.data.filter(invoice => {\n    // If nothing is selected in the store, show all invoices\n    if (!appsmith.store.selectedVendor) return true;\n    \n    // 1. Extract the ID or Name from the store variable dynamically\n    const selectedStoreValue = typeof appsmith.store.selectedVendor === 'object'\n      ? (appsmith.store.selectedVendor.id || appsmith.store.selectedVendor.vendor_name)\n      : appsmith.store.selectedVendor;\n      \n    // 2. Clean and format strings for safe, case-insensitive comparison\n    const targetMatch = String(selectedStoreValue).toLowerCase().trim();\n    const currentInvoiceVendorId = String(invoice.vendor_id).toLowerCase().trim();\n    const currentInvoiceVendorName = String(invoice.vendor_name).toLowerCase().trim();\n    \n    // 3. Match against either ID or Name\n    return currentInvoiceVendorId === targetMatch || currentInvoiceVendorName.includes(targetMatch);\n  }) \n}}",
