    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Trip Audit Dashboard</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg-main: #0a0c10;\n            --bg-card: #161b22;\n            --text-primary: #f0f6fc;\n            --text-secondary: #8b949e;\n            --accent-green: #3fb950;\n            --accent-blue: #2188ff;\n            --accent-red: #f85149;\n            --accent-gold: #d29922;\n            --border: #30363d;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }\n        body { background-color: var(--bg-main); color: var(--text-primary); padding: 20px; overflow-x: hidden; }\n\n        /* Header Bar */\n        .trip-header { \n            background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; \n            padding: 16px 24px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;\n        }\n        .trip-badge { background: rgba(63, 185, 80, 0.1); color: var(--accent-green); padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; border: 1px solid var(--accent-green); }\n\n        /* Scorecard */\n        .scorecard { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }\n        .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }\n        .stat-label { font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); letter-spacing: 1px; margin-bottom: 8px; }\n        .stat-value { font-size: 24px; font-weight: 700; color: #fff; }\n\n        /* Layout */\n        .main-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; }\n        @media (max-width: 1000px) { .main-grid { grid-template-columns: 1fr; } }\n\n        .section-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 20px; }\n        .section-title { font-size: 14px; font-weight: 600; color: #fff; margin-bottom: 16px; display: flex; justify-content: space-between; }\n\n        /* Tables & Lists */\n        .scroll-area { max-height: 400px; overflow-y: auto; padding-right: 8px; }\n        .scroll-area::-webkit-scrollbar { width: 4px; }\n        .scroll-area::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }\n\n        .list-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); }\n        .list-row:last-child { border-bottom: none; }\n        .row-info b { display: block; font-size: 13px; color: var(--text-primary); }\n        .row-info span { font-size: 11px; color: var(--text-secondary); }\n        .row-val { text-align: right; font-size: 13px; font-weight: 600; }\n\n        .pill { font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: 700; margin-left: 8px; }\n        .pill-blue { background: rgba(33, 136, 255, 0.15); color: var(--accent-blue); }\n        .pill-red { background: rgba(248, 81, 73, 0.15); color: var(--accent-red); }\n    </style>\n</head>\n<body>\n\n    <!-- Top Bar -->\n    <div class=\"trip-header\" id=\"trip-header-ui\">\n        <div>\n            <span style=\"color: var(--text-secondary); font-size: 12px;\">TRIP ID</span>\n            <h2 style=\"font-size: 20px;\" id=\"header-trip-id\">#--</h2>\n        </div>\n        <div style=\"text-align: right;\">\n            <div class=\"trip-badge\" id=\"header-status\">CHECKED</div>\n            <p id=\"header-sync\" style=\"font-size: 11px; color: var(--text-secondary); margin-top: 6px;\">Synced via --</p>\n        </div>\n    </div>\n\n    <!-- Scorecard -->\n    <div class=\"scorecard\" id=\"main-scorecard\">\n        <div class=\"stat-card\">\n            <div class=\"stat-label\">Deliveries</div>\n            <div class=\"stat-value\" id=\"val-del-count\">0</div>\n            <div style=\"font-size: 11px; color: var(--accent-green); margin-top: 4px;\" id=\"val-del-amt\">₹0.00</div>\n        </div>\n        <div class=\"stat-card\">\n            <div class=\"stat-label\">Collections</div>\n            <div class=\"stat-value\" id=\"val-pay-amt\" style=\"color: var(--accent-blue);\">₹0</div>\n            <div style=\"font-size: 11px; color: var(--text-secondary); margin-top: 4px;\" id=\"val-pay-count\">0 Payments</div>\n        </div>\n        <div class=\"stat-card\">\n            <div class=\"stat-label\">Returns</div>\n            <div class=\"stat-value\" id=\"val-ret-count\" style=\"color: var(--accent-red);\">0</div>\n            <div style=\"font-size: 11px; color: var(--text-secondary); margin-top: 4px;\">Items Processed</div>\n        </div>\n        <div class=\"stat-card\">\n            <div class=\"stat-label\">Credit Notes</div>\n            <div class=\"stat-value\" id=\"val-cn-amt\" style=\"color: var(--accent-gold);\">₹0</div>\n            <div style=\"font-size: 11px; color: var(--text-secondary); margin-top: 4px;\" id=\"val-cn-count\">0 Issued</div>\n        </div>\n    </div>\n\n    <div class=\"main-grid\">\n        <!-- Deliveries & Returns Feed -->\n        <div>\n            <div class=\"section-card\">\n                <div class=\"section-title\">Delivery Activity Log <span id=\"sync-time\" style=\"font-size: 11px; font-weight: normal; color: var(--text-secondary);\"></span></div>\n                <div class=\"scroll-area\" id=\"delivery-list\"></div>\n            </div>\n            \n            <div class=\"section-card\">\n                <div class=\"section-title\">Inventory Returns</div>\n                <div class=\"scroll-area\" id=\"returns-list\"></div>\n            </div>\n        </div>\n\n        <!-- Financials & Summary -->\n        <div>\n            <div class=\"section-card\">\n                <div class=\"section-title\">Financial Summary (Payments)</div>\n                <div class=\"scroll-area\" id=\"payments-list\"></div>\n            </div>\n\n            <div class=\"section-card\">\n                <div class=\"section-title\">Product Movement Summary</div>\n                <div class=\"scroll-area\" id=\"product-summary\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        const f = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n\n        function update(data) {\n            if (!data || !data.header) return;\n\n            // Header\n            document.getElementById('header-trip-id').innerText = \"#\" + data.header.trip_id;\n            document.getElementById('header-status').innerText = data.header.status.toUpperCase();\n            document.getElementById('header-sync').innerText = \"Synced via \" + data.header.payload_summary.sync_source;\n            document.getElementById('sync-time').innerText = \"Process Date: \" + new Date(data.header.created_at).toLocaleDateString();\n\n            // Scorecard\n            const totalDelAmt = (data.delivered || []).reduce((acc, curr) => acc + parseFloat(curr.grand_total), 0);\n            const totalPayAmt = (data.payments || []).reduce((acc, curr) => acc + parseFloat(curr.amount), 0);\n            const totalCNAmt = (data.credit_notes || []).reduce((acc, curr) => acc + parseFloat(curr.grand_total), 0);\n\n            document.getElementById('val-del-count').innerText = data.delivered.length;\n            document.getElementById('val-del-amt').innerText = f(totalDelAmt);\n            document.getElementById('val-pay-amt').innerText = f(totalPayAmt);\n            document.getElementById('val-pay-count').innerText = data.payments.length + \" Payments\";\n            document.getElementById('val-ret-count').innerText = data.returns.length;\n            document.getElementById('val-cn-amt').innerText = f(totalCNAmt);\n            document.getElementById('val-cn-count').innerText = data.credit_notes.length + \" Issued\";\n\n            // List: Deliveries\n            document.getElementById('delivery-list').innerHTML = (data.delivered || []).map(item => `\n                <div class=\"list-row\">\n                    <div class=\"row-info\">\n                        <b>${item.customer_name}</b>\n                        <span>${item.invoice_number} • ${new Date(item.delivery_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>\n                    </div>\n                    <div class=\"row-val\">\n                        ${f(item.grand_total)}\n                        <div style=\"font-size: 10px; color: var(--accent-green)\">${item.verification_status}</div>\n                    </div>\n                </div>\n            `).join('');\n\n            // List: Returns\n            document.getElementById('returns-list').innerHTML = (data.returns || []).map(item => `\n                <div class=\"list-row\">\n                    <div class=\"row-info\">\n                        <b>${item.product_name}</b>\n                        <span>${item.customer_name} • ${item.reason}</span>\n                    </div>\n                    <div class=\"row-val\">\n                        Qty: ${item.qty}\n                        <div class=\"pill pill-red\">${item.condition}</div>\n                    </div>\n                </div>\n            `).join('');\n\n            // List: Payments\n            document.getElementById('payments-list').innerHTML = (data.payments || []).map(item => `\n                <div class=\"list-row\">\n                    <div class=\"row-info\">\n                        <b>${item.customer_name}</b>\n                        <span>Mode: ${item.payment_mode} • Ref: ${item.payment_number}</span>\n                    </div>\n                    <div class=\"row-val\" style=\"color: var(--accent-blue)\">\n                        ${f(item.amount)}\n                        <div style=\"font-size: 10px; color: var(--text-secondary)\">${item.verification_status}</div>\n                    </div>\n                </div>\n            `).join('');\n\n            // List: Product Summary\n            document.getElementById('product-summary').innerHTML = (data.delivered_summary || []).slice(0, 10).map(item => `\n                <div class=\"list-row\">\n                    <div class=\"row-info\">\n                        <b style=\"font-size: 11px;\">${item.product_name}</b>\n                        <span>MRP: ${f(item.mrp)}</span>\n                    </div>\n                    <div class=\"row-val\">\n                        ${item.total_qty} units\n                        <div style=\"font-size: 10px; color: var(--text-secondary)\">${f(item.total_amount)}</div>\n                    </div>\n                </div>\n            `).join('');\n        }\n\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
