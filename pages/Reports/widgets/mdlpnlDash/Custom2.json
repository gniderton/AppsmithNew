    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Gniderton P&L Dashboard</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        :root {\n            --bg-main: #0a0c10;\n            --bg-card: #161b22;\n            --text-primary: #f0f6fc;\n            --text-secondary: #8b949e;\n            --accent-revenue: #3fb950;\n            --accent-expense: #f85149;\n            --accent-profit: #2188ff;\n            --accent-gold: #d29922;\n            --border: #30363d;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }\n        body { background-color: var(--bg-main); color: var(--text-primary); padding: 24px; overflow-x: hidden; }\n\n        .header { margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end; }\n        .header h1 { font-size: 24px; font-weight: 700; color: #fff; }\n        .header p { color: var(--text-secondary); font-size: 13px; margin-top: 4px; }\n\n        /* KPI Cards */\n        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px; }\n        .kpi-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; transition: 0.2s; }\n        .kpi-card:hover { border-color: #555; transform: translateY(-2px); }\n        .kpi-label { font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); letter-spacing: 1px; margin-bottom: 12px; }\n        .kpi-value { font-size: 28px; font-weight: 700; color: #fff; }\n        .kpi-margin { font-size: 13px; font-weight: 600; margin-top: 8px; display: inline-block; padding: 2px 8px; border-radius: 4px; }\n        .margin-pos { background: rgba(63, 185, 80, 0.15); color: var(--accent-revenue); }\n\n        /* Content Layout */\n        .main-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 24px; }\n        @media (max-width: 1000px) { .main-layout { grid-template-columns: 1fr; } }\n\n        .section-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 24px; }\n        .section-title { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }\n\n        /* Line Items */\n        .line-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }\n        .line-item:last-child { border-bottom: none; }\n        .line-info b { font-size: 13px; display: block; color: var(--text-primary); }\n        .line-info span { font-size: 11px; color: var(--text-secondary); }\n        .line-val { text-align: right; font-size: 13px; font-weight: 600; }\n        .line-bar-container { width: 100%; height: 4px; background: #222; border-radius: 2px; margin-top: 8px; overflow: hidden; }\n        .line-bar { height: 100%; background: var(--accent-gold); opacity: 0.6; }\n\n        .total-row { margin-top: 10px; padding-top: 15px; border-top: 2px solid var(--border); display: flex; justify-content: space-between; font-weight: 700; color: #fff; }\n\n        /* Chart Styling */\n        .chart-box { height: 300px; display: flex; flex-direction: column; align-items: center; justify-content: center; }\n    </style>\n</head>\n<body>\n\n    <div class=\"header\">\n        <div>\n            <h1>Profit & Loss Statement</h1>\n            <p id=\"period-text\">Reporting Period: Loading...</p>\n        </div>\n        <div id=\"sync-status\" style=\"font-size: 11px; color: var(--text-secondary);\">Connecting...</div>\n    </div>\n\n    <!-- KPI Row -->\n    <div class=\"kpi-grid\" id=\"kpi-row\">\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Total Revenue</div><div class=\"kpi-value\" id=\"val-rev\">₹0</div></div>\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Gross Profit</div><div class=\"kpi-value\" id=\"val-gp\">₹0</div><div class=\"kpi-margin margin-pos\" id=\"val-gm\">0%</div></div>\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Net Profit</div><div class=\"kpi-value\" id=\"val-np\" style=\"color: var(--accent-revenue)\">₹0</div><div class=\"kpi-margin margin-pos\" id=\"val-nm\">0%</div></div>\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Operating Expenses</div><div class=\"kpi-value\" id=\"val-exp\" style=\"color: var(--accent-expense)\">₹0</div></div>\n    </div>\n\n    <div class=\"main-layout\">\n        <!-- Details Column -->\n        <div>\n            <div class=\"section-card\">\n                <div class=\"section-title\">Revenue & Direct Costs</div>\n                <div id=\"revenue-details\"></div>\n            </div>\n            \n            <div class=\"section-card\">\n                <div class=\"section-title\">Operating Expenses (Indirect)</div>\n                <div id=\"expense-details\"></div>\n            </div>\n        </div>\n\n        <!-- Insights Column -->\n        <div>\n            <div class=\"section-card\">\n                <div class=\"section-title\">Profitability Mix</div>\n                <div class=\"chart-box\">\n                    <canvas id=\"marginChart\"></canvas>\n                </div>\n                <div style=\"margin-top: 24px; font-size: 12px; color: var(--text-secondary); line-height: 1.6;\">\n                    * Net Margin indicates the percentage of revenue remaining after all operating expenses, interest, and taxes are paid.\n                </div>\n            </div>\n\n            <div class=\"section-card\">\n                <div class=\"section-title\">Other Income</div>\n                <div id=\"income-details\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let marginChart;\n        const f = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n\n        function renderSection(id, lines, total) {\n            const container = document.getElementById(id);\n            const maxVal = Math.max(...lines.map(l => Math.abs(l.amount)));\n            \n            container.innerHTML = lines.map(line => `\n                <div class=\"line-item\">\n                    <div style=\"flex: 1\">\n                        <div class=\"line-info\">\n                            <b>${line.name}</b>\n                            <span>Account Code: ${line.code}</span>\n                        </div>\n                        <div class=\"line-bar-container\">\n                            <div class=\"line-bar\" style=\"width: ${(Math.abs(line.amount)/maxVal)*100}%\"></div>\n                        </div>\n                    </div>\n                    <div class=\"line-val\" style=\"color: ${line.amount < 0 ? 'var(--accent-expense)' : 'var(--text-primary)'}\">\n                        ${f(line.amount)}\n                    </div>\n                </div>\n            `).join('') + `\n            <div class=\"total-row\">\n                <span>Total ${id.split('-')[0].toUpperCase()}</span>\n                <span>${f(total)}</span>\n            </div>`;\n        }\n\n        function update(data) {\n            if (!data || !data.summary) return;\n            document.getElementById('sync-status').innerText = \"Last Updated: \" + new Date().toLocaleTimeString();\n            document.getElementById('period-text').innerText = `Reporting Period: ${data.period.start} to ${data.period.end}`;\n\n            // Update KPIs\n            const s = data.summary;\n            document.getElementById('val-rev').innerText = f(s.total_revenue);\n            document.getElementById('val-gp').innerText = f(s.gross_profit);\n            document.getElementById('val-np').innerText = f(s.net_profit);\n            document.getElementById('val-exp').innerText = f(s.operating_expenses);\n            document.getElementById('val-gm').innerText = \"GM: \" + s.gross_margin;\n            document.getElementById('val-nm').innerText = \"NM: \" + s.net_margin;\n\n            // Render Sections\n            renderSection('revenue-details', [...data.sections.revenue.lines, ...data.sections.cogs.lines], s.gross_profit);\n            renderSection('expense-details', data.sections.operating_expenses.lines, data.sections.operating_expenses.total);\n            renderSection('income-details', data.sections.other_income.lines, data.sections.other_income.total);\n\n            // Margin Chart\n            if (marginChart) marginChart.destroy();\n            marginChart = new Chart(document.getElementById('marginChart'), {\n                type: 'doughnut',\n                data: {\n                    labels: ['COGS', 'OpEx', 'Net Profit'],\n                    datasets: [{\n                        data: [s.total_cogs, s.operating_expenses, s.net_profit],\n                        backgroundColor: ['#d29922', '#f85149', '#3fb950'],\n                        borderWidth: 0,\n                        hoverOffset: 15\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    cutout: '75%',\n                    plugins: {\n                        legend: { position: 'bottom', labels: { color: '#8b949e', font: { size: 10 }, padding: 20 } }\n                    }\n                }\n            });\n        }\n\n        // FAIL-PROOF CONNECTION\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
