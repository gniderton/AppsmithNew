lass=\"kpi-grid\" id=\"kpi-row\">\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Total Revenue</div><div class=\"kpi-value\" id=\"val-rev\">₹0</div></div>\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Gross Profit</div><div class=\"kpi-value\" id=\"val-gp\">₹0</div><div class=\"kpi-margin margin-pos\" id=\"val-gm\">0%</div></div>\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Net Profit</div><div class=\"kpi-value\" id=\"val-np\" style=\"color: var(--accent-revenue)\">₹0</div><div class=\"kpi-margin margin-pos\" id=\"val-nm\">0%</div></div>\n        <div class=\"kpi-card\"><div class=\"kpi-label\">Operating Expenses</div><div class=\"kpi-value\" id=\"val-exp\" style=\"color: var(--accent-expense)\">₹0</div></div>\n    </div>\n\n    <div class=\"main-layout\">\n        <!-- Details Column -->\n        <div>\n            <div class=\"section-card\">\n                <div class=\"section-title\">Revenue & Direct Costs</div>\n                <div id=\"revenue-details\"></div>\n            </div>\n            \n            <div class=\"section-card\">\n                <div class=\"section-title\">Operating Expenses (Indirect)</div>\n                <div id=\"expense-details\"></div>\n            </div>\n        </div>\n\n        <!-- Insights Column -->\n        <div>\n            <div class=\"section-card\">\n                <div class=\"section-title\">Profitability Mix</div>\n                <div class=\"chart-box\">\n                    <canvas id=\"marginChart\"></canvas>\n                </div>\n                <div style=\"margin-top: 24px; font-size: 12px; color: var(--text-secondary); line-height: 1.6;\">\n                    * Net Margin indicates the percentage of revenue remaining after all operating expenses, interest, and taxes are paid.\n                </div>\n            </div>\n\n            <div class=\"section-card\">\n                <div class=\"section-title\">Other Income</div>\n                <div id=\"income-details\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let marginChart;\n        const f = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n\n        function renderSection(id, lines, total) {\n            const container = document.getElementById(id);\n            const maxVal = Math.max(...lines.map(l => Math.abs(l.amount)));\n            \n            container.innerHTML = lines.map(line => `\n                <div class=\"line-item\">\n                    <div style=\"flex: 1\">\n                        <div class=\"line-info\">\n                            <b>${line.name}</b>\n                            <span>Account Code: ${line.code}</span>\n                        </div>\n                        <div class=\"line-bar-container\">\n                            <div class=\"line-bar\" style=\"width: ${(Math.abs(line.amount)/maxVal)*100}%\"></div>\n                        </div>\n                    </div>\n                    <div class=\"line-val\" style=\"color: ${line.amount < 0 ? 'var(--accent-expense)' : 'var(--text-primary)'}\">\n                        ${f(line.amount)}\n                    </div>\n                </div>\n            `).join('') + `\n            <div class=\"total-row\">\n                <span>Total ${id.split('-')[0].toUpperCase()}</span>\n                <span>${f(total)}</span>\n            </div>`;\n        }\n\n        function update(data) {\n            if (!data || !data.summary) return;\n            document.getElementById('sync-status').innerText = \"Last Updated: \" + new Date().toLocaleTimeString();\n            document.getElementById('period-text').innerText = `Reporting Period: ${data.period.start} to ${data.period.end}`;\n\n            // Update KPIs\n            const s = data.summary;\n            document.getElementById('val-rev').innerText = f(s.total_revenue);\n            document.getElementById('val-gp').innerText = f(s.gross_profit);\n            document.getElementById('val-np').innerText = f(s.net_profit);\n            document.getElementById('val-exp').innerText = f(s.operating_expenses);\n            document.getElementById('val-gm').innerText = \"GM: \" + s.gross_margin;\n            document.getElementById('val-nm').innerText = \"NM: \" + s.net_margin;\n\n            // Render Sections\n            renderSection('revenue-details', [...data.sections.revenue.lines, ...data.sections.cogs.lines], s.gross_profit);\n            renderSection('expense-details', data.sections.operating_expenses.lines, data.sections.operating_expenses.total);\n            renderSection('income-details', data.sections.other_income.lines, data.sections.other_income.total);\n\n            // Margin Chart\n            if (marginChart) marginChart.destroy();\n            marginChart = new Chart(document.getElementById('marginChart'), {\n                type: 'doughnut',\n                data: {\n                    labels: ['COGS', 'OpEx', 'Net Profit'],\n                    datasets: [{\n                        data: [s.total_cogs, s.operating_expenses, s.net_profit],\n                        backgroundColor: ['#d29922', '#f85149', '#3fb950'],\n                        borderWidth: 0,\n                        hoverOffset: 15\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    cutout: '75%',\n                    plugins: {\n                        legend: { position: 'bottom', labels: { color: '#8b949e', font: { size: 10 }, padding: 20 } }\n                    }\n                }\n            });\n        }\n\n        // FAIL-PROOF CONNECTION\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
    "js": "import React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\n\nconst Button = ({ children, className, ...props }) => (\n  <button className={className} {...props}>\n    {children}\n  </button>\n);\n\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n\n  const handleNext = () => {\n    setCurrentIndex((prevIndex) => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n\n  return (\n    <div className=\"app\">\n      <div className=\"tip-container\">\n        <div className=\"tip-header\">\n          <h2>Custom Widget</h2>\n          <div>{currentIndex + 1} / {appsmith.model.tips.length}</div>\n        </div>\n        <div className=\"content\">{appsmith.model.tips[currentIndex]}</div>\n      </div>\n      <div className=\"button-container\">\n        <Button className=\"primary\" onClick={handleNext}>Next Tip</Button>\n        <Button className=\"reset\" disabled={currentIndex === 0} onClick={handleReset}>Reset</Button>\n      </div>\n    </div>\n  );\n}\n\nappsmith.onReady(() => {\n/*\n\t * This handler function will get called when parent application is ready.\n\t * Initialize your component here\n\t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n\t */\n    ReactDOM.render(<App />, document.getElementById(\"root\"));\n});"
  },
