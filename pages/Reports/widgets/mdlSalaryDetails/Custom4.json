    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Employee Salary Forensic Dashboard</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        :root {\n            --bg-main: #0d1117;\n            --bg-card: #161b22;\n            --text-primary: #f0f6fc;\n            --text-secondary: #8b949e;\n            --accent-green: #3fb950;\n            --accent-blue: #2188ff;\n            --accent-red: #f85149;\n            --accent-orange: #d29922;\n            --border: #30363d;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }\n        body { background-color: var(--bg-main); color: var(--text-primary); padding: 20px; overflow-x: hidden; }\n\n        .dashboard-header { margin-bottom: 24px; display: flex; justify-content: space-between; align-items: flex-end; }\n        .header-left h1 { font-size: 20px; font-weight: 600; color: #fff; }\n        .header-left p { color: var(--text-secondary); font-size: 13px; margin-top: 4px; }\n        .month-pill { background: rgba(33, 136, 255, 0.1); border: 1px solid var(--accent-blue); color: var(--accent-blue); padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }\n\n        .grid-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }\n        .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 18px; transition: transform 0.2s ease; }\n        .card:hover { transform: translateY(-2px); border-color: #444; }\n        .card-label { color: var(--text-secondary); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }\n        .card-value { font-size: 24px; font-weight: 700; margin-bottom: 4px; }\n        .card-subtext { font-size: 11px; color: var(--text-secondary); }\n        .card-subtext b { color: var(--text-primary); }\n\n        .grid-main { display: grid; grid-template-columns: 1fr 1.5fr; gap: 20px; margin-bottom: 20px; }\n        @media (max-width: 900px) { .grid-main { grid-template-columns: 1fr; } }\n\n        .chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;}\n        .section-title { font-size: 13px; font-weight: 600; margin-bottom: 18px; color: #fff; text-transform: uppercase; width: 100%; text-align: left; }\n\n        .breakdown-lists { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n        .scroll-list { max-height: 250px; overflow-y: auto; background: rgba(0,0,0,0.1); padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.03); }\n        .list-item { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); }\n        .list-item:last-child { border-bottom: none; }\n        .item-info p { font-size: 12px; font-weight: 500; color: var(--text-primary); }\n        .item-info span { font-size: 10px; color: var(--text-secondary); }\n        .item-value { font-size: 12px; font-weight: 600; }\n\n        .footer-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 20px; }\n        .mini-card { background: rgba(255,255,255,0.02); padding: 12px; border-radius: 8px; border: 1px solid var(--border); }\n        .mini-label { font-size: 9px; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 4px; }\n        .mini-val { font-size: 12px; font-weight: 500; }\n\n        .net-glow { color: var(--accent-green); text-shadow: 0 0 15px rgba(63, 185, 80, 0.3); }\n        .deduct-color { color: var(--accent-red); }\n    </style>\n</head>\n<body>\n\n    <div class=\"dashboard-header\">\n        <div class=\"header-left\">\n            <h1 id=\"employee-name\">Loading...</h1>\n            <p id=\"employee-meta\">Employee ID: -- | Joining: --</p>\n        </div>\n        <div class=\"month-pill\" id=\"period-label\">APR 2026</div>\n    </div>\n\n    <!-- Top KPIs -->\n    <div class=\"grid-kpis\">\n        <div class=\"card\">\n            <div class=\"card-label\">Net Payout</div>\n            <div class=\"card-value net-glow\" id=\"net-salary\">₹ 0</div>\n            <div class=\"card-subtext\" id=\"payout-mode\">Via --</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Gross Earnings</div>\n            <div class=\"card-value\" id=\"gross-earnings\">₹ 0</div>\n            <div class=\"card-subtext\">Base + Bonus + Encash</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Total Deductions</div>\n            <div class=\"card-value deduct-color\" id=\"total-deductions\">₹ 0</div>\n            <div class=\"card-subtext\">Advances + Loans + Liabs</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Attendance</div>\n            <div class=\"card-value\" id=\"attendance-stat\">0/30</div>\n            <div class=\"card-subtext\" id=\"absent-breakdown\">0 Abs | 0 Half Days</div>\n        </div>\n    </div>\n\n    <!-- Main Section -->\n    <div class=\"grid-main\">\n        <div class=\"chart-container\">\n            <div class=\"section-title\">Salary Composition</div>\n            <div style=\"height: 220px; width: 100%; position: relative;\">\n                <canvas id=\"salaryChart\"></canvas>\n            </div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">Earnings Breakdown</div>\n            <div class=\"scroll-list\" id=\"earnings-list\">\n                <!-- Injected via JS -->\n            </div>\n            <div class=\"section-title\" style=\"margin-top: 20px;\">Deductions & Recoveries</div>\n            <div class=\"scroll-list\" id=\"deductions-list\">\n                <!-- Injected via JS -->\n            </div>\n        </div>\n    </div>\n\n    <!-- Footer Metadata -->\n    <div class=\"footer-row\">\n        <div class=\"mini-card\">\n            <div class=\"mini-label\">Source Account</div>\n            <div class=\"mini-val\" id=\"source-acc\">--</div>\n        </div>\n        <div class=\"mini-card\">\n            <div class=\"mini-label\">Processed By</div>\n            <div class=\"mini-val\" id=\"processed-by\">--</div>\n        </div>\n        <div class=\"mini-card\">\n            <div class=\"mini-label\">Reference ID</div>\n            <div class=\"mini-val\" id=\"ref-id\">#--</div>\n        </div>\n    </div>\n\n    <script>\n        let salaryChart = null;\n        const fmt = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n        const getMonthName = (m) => [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\", \"Jul\", \"Aug\", \"Sep\", \"Oct\", \"Nov\", \"Dec\"][m - 1];\n\n        function update(data) {\n            if (!data || !data.header) return;\n            const h = data.header, b = data.breakdown;\n\n            // Totals\n            const gross = Number(b.base_salary.adjusted || h.base_salary) + \n                          (b.additions.bonuses || []).reduce((s, x) => s + Number(x.amount), 0) + \n                          Number(b.additions.leave_encashment);\n            \n            const totalDeducts = (b.deductions.advances || []).reduce((s, x) => s + Number(x.amount), 0) + \n                                 (b.deductions.liabilities || []).reduce((s, x) => s + Number(x.amount), 0) + \n                                 (b.deductions.loans || []).reduce((s, x) => s + Number(x.amount), 0) + \n                                 Number(b.deductions.leave.amount);\n\n            // Header & KPIs\n            document.getElementById('employee-name').innerText = h.full_name;\n            document.getElementById('employee-meta').innerText = `ID: ${h.employee_code} | Joined: ${new Date(h.joining_date).toLocaleDateString('en-GB')}`;\n            document.getElementById('period-label').innerText = `${getMonthName(h.month)} ${h.year}`.toUpperCase();\n            \n            document.getElementById('net-salary').innerText = fmt(h.net_salary);\n            document.getElementById('payout-mode').innerText = `Via ${h.payment_mode}`;\n            document.getElementById('gross-earnings').innerText = fmt(gross);\n            document.getElementById('total-deductions').innerText = fmt(totalDeducts);\n            document.getElementById('attendance-stat').innerText = `${30 - h.absent_days}/30`;\n            document.getElementById('absent-breakdown').innerText = `${h.absent_days} Abs | ${h.half_days} Half Days`;\n\n            // Metadata\n            document.getElementById('source-acc').innerText = h.source_account.split('(')[0];\n            document.getElementById('processed-by').innerText = h.processed_by;\n            document.getElementById('ref-id').innerText = `#SAL-${h.id}`;\n\n            // Earnings List\n            let earningsHtml = `\n                <div class=\"list-item\"><div class=\"item-info\"><p>Base Salary (Adjusted)</p></div><div class=\"item-value\">${fmt(b.base_salary.adjusted || h.base_salary)}</div></div>\n            `;\n            (b.additions.bonuses || []).forEach(bn => {\n                earningsHtml += `<div class=\"list-item\"><div class=\"item-info\"><p>${bn.remarks || bn.bonus_type}</p><span>Bonus</span></div><div class=\"item-value\">${fmt(bn.amount)}</div></div>`;\n            });\n            if(Number(b.additions.leave_encashment) > 0) {\n                earningsHtml += `<div class=\"list-item\"><div class=\"item-info\"><p>Leave Encashment</p></div><div class=\"item-value\">${fmt(b.additions.leave_encashment)}</div></div>`;\n            }\n            document.getElementById('earnings-list').innerHTML = earningsHtml;\n\n            // Deductions List\n            let deductHtml = \"\";\n            if(Number(b.deductions.leave.amount) > 0) {\n                deductHtml += `<div class=\"list-item\"><div class=\"item-info\"><p>Leave Deduction</p><span>${h.absent_days} days</span></div><div class=\"item-value deduct-color\">${fmt(b.deductions.leave.amount)}</div></div>`;\n            }\n            (b.deductions.advances || []).forEach(ad => {\n                deductHtml += `<div class=\"list-item\"><div class=\"item-info\"><p>Advance Recovery</p><span>${new Date(ad.date).toLocaleDateString()}</span></div><div class=\"item-value deduct-color\">${fmt(ad.amount)}</div></div>`;\n            });\n            (b.deductions.liabilities || []).forEach(lb => {\n                deductHtml += `<div class=\"list-item\"><div class=\"item-info\"><p>${lb.description}</p><span>${lb.invoice_number || lb.type}</span></div><div class=\"item-value deduct-color\">${fmt(lb.amount)}</div></div>`;\n            });\n             (b.deductions.loans || []).forEach(ln => {\n                deductHtml += `<div class=\"list-item\"><div class=\"item-info\"><p>Loan EMI</p></div><div class=\"item-value deduct-color\">${fmt(ln.amount)}</div></div>`;\n            });\n            document.getElementById('deductions-list').innerHTML = deductHtml || '<div class=\"list-item\" style=\"color:var(--text-secondary); font-size:11px;\">No deductions applied this month</div>';\n\n            // Chart\n            const ctx = document.getElementById('salaryChart').getContext('2d');\n            if (salaryChart) salaryChart.destroy();\n            salaryChart = new Chart(ctx, {\n                type: 'doughnut',\n                data: {\n                    labels: ['Net Salary', 'Deductions'],\n                    datasets: [{\n                        data: [h.net_salary, totalDeducts],\n                        backgroundColor: [ '#3fb950', '#f85149' ],\n                        borderWidth: 0,\n                        hoverOffset: 10\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    cutout: '80%',\n                    plugins: { legend: { display: false } }\n                }\n            });\n        }\n\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
    "js": "function _extends() { return _extends = Object.assign ? Object.assign.bind() : function (n) { for (var e = 1; e < arguments.length; e++) { var t = arguments[e]; for (var r in t) ({}).hasOwnProperty.call(t, r) && (n[r] = t[r]); } return n; }, _extends.apply(null, arguments); }\nimport React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\nconst Button = ({\n  children,\n  className,\n  ...props\n}) => /*#__PURE__*/React.createElement(\"button\", _extends({\n  className: className\n}, props), children);\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n  const handleNext = () => {\n    setCurrentIndex(prevIndex => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"app\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-header\"\n  }, /*#__PURE__*/React.createElement(\"h2\", null, \"Custom Widget\"), /*#__PURE__*/React.createElement(\"div\", null, currentIndex + 1, \" / \", appsmith.model.tips.length)), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"content\"\n  }, appsmith.model.tips[currentIndex])), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"button-container\"\n  }, /*#__PURE__*/React.createElement(Button, {\n    className: \"primary\",\n    onClick: handleNext\n  }, \"Next Tip\"), /*#__PURE__*/React.createElement(Button, {\n    className: \"reset\",\n    disabled: currentIndex === 0,\n    onClick: handleReset\n  }, \"Reset\")));\n}\nappsmith.onReady(() => {\n  /*\n  \t * This handler function will get called when parent application is ready.\n  \t * Initialize your component here\n  \t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n  \t */\n  ReactDOM.render(/*#__PURE__*/React.createElement(App, null), document.getElementById(\"root\"));\n});"
