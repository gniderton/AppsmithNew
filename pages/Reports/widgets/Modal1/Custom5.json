ed); }\n\n        .card-label { color: var(--text-secondary); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px; }\n        .card-value { font-size: 28px; font-weight: 700; margin-bottom: 4px; }\n        .card-subtext { font-size: 12px; color: var(--text-secondary); margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }\n        .card-subtext b { color: var(--text-primary); }\n\n        .grid-main { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 15px; margin-bottom: 15px; }\n        @media (max-width: 1200px) { .grid-main { grid-template-columns: 1fr; } }\n\n        .section-title { font-size: 15px; font-weight: 600; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; }\n        .section-title i { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-blue); }\n\n        .scroll-list { max-height: 350px; overflow-y: auto; padding-right: 8px; }\n        .list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-radius: 8px; margin-bottom: 8px; background: rgba(255,255,255,0.02); }\n        .item-info p { font-size: 13px; font-weight: 500; color: #e2e8f0; width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n        .item-info span { font-size: 11px; color: var(--text-secondary); }\n        .item-value { font-size: 13px; font-weight: 700; }\n\n        .chart-box { height: 280px; width: 100%; margin-top: 10px; }\n    </style>\n</head>\n<body>\n\n    <div class=\"dashboard-header\">\n        <div class=\"header-left\">\n            <h1>Forensic Liquid Ledger</h1>\n            <p>Physical Reality Financial Engine • Corporate View</p>\n        </div>\n        <div style=\"color: var(--accent-green); font-size: 11px; font-weight: 600;\">● LIVE CONNECTION</div>\n    </div>\n\n    <!-- 1. Primary Capital KPIs -->\n    <div class=\"grid-overview\">\n        <div class=\"card capital\">\n            <div class=\"card-label\">Current Net Capital</div>\n            <div class=\"card-value\" id=\"val-net-capital\">₹0</div>\n            <div class=\"card-subtext\">Capital Efficiency: <b id=\"val-efficiency\">--%</b></div>\n        </div>\n        <div class=\"card assets\">\n            <div class=\"card-label\">Total Forensic Assets</div>\n            <div class=\"card-value\" id=\"val-total-assets\">₹0</div>\n            <div class=\"card-subtext\">Physical Source of Truth</div>\n        </div>\n        <div class=\"card liabilities\">\n            <div class=\"card-label\">Total Forensic Liabilities</div>\n            <div class=\"card-value\" id=\"val-total-liabs\">₹0</div>\n            <div class=\"card-subtext\">Payables & Obligations</div>\n        </div>\n    </div>\n\n    <!-- 2. The Main Radar and Lists -->\n    <div class=\"grid-main\">\n        <div class=\"card\">\n            <div class=\"section-title\"><i></i>Liquidity Radar</div>\n            <div class=\"chart-box\"><canvas id=\"liquidityChart\"></canvas></div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\"><i></i>Top Debtors (Receivables)</div>\n            <div class=\"scroll-list\" id=\"receivables-list\"></div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\"><i></i>Top Creditors (Payables)</div>\n            <div class=\"scroll-list\" id=\"payables-list\"></div>\n        </div>\n    </div>\n\n    <!-- 3. Secondary Metrics (The ones we missed!) -->\n    <div class=\"grid-overview\">\n        <div class=\"card\">\n            <div class=\"card-label\">Inventory Valuation</div>\n            <div class=\"card-value\" id=\"val-stock\" style=\"font-size: 22px;\">₹0</div>\n            <div class=\"card-subtext\">Across <b id=\"val-stock-count\">0</b> Products</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Monthly Operating Expenses</div>\n            <div class=\"card-value\" id=\"val-expenses\" style=\"font-size: 22px;\">₹0</div>\n            <div class=\"card-subtext\">Fuel, Rent, Logistics & Payroll</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Active Loans (Taken)</div>\n            <div class=\"card-value\" id=\"val-loans\" style=\"font-size: 22px;\">₹0</div>\n            <div class=\"card-subtext\">Ongoing Monthly Obligations</div>\n        </div>\n    </div>\n\n    <script>\n        let charts = {};\n        let lastUpdateString = \"\";\n        const fmt = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n\n        function update(data) {\n            if (!data || !data.summary) return;\n            \n            // Stable Update Logic: Only refresh charts if data actually changed\n            const currentString = JSON.stringify(data.summary);\n            const isChange = currentString !== lastUpdateString;\n            lastUpdateString = currentString;\n\n            const s = data.summary;\n            const b = s.breakdown;\n\n            // Header KPIs\n            document.getElementById('val-net-capital').innerText = fmt(s.net_capital);\n            document.getElementById('val-total-assets').innerText = fmt(s.total_assets);\n            document.getElementById('val-total-liabs').innerText = fmt(s.total_liabilities);\n            document.getElementById('val-efficiency').innerText = (parseFloat(s.net_capital) / parseFloat(s.total_assets) * 100).toFixed(1) + \"%\";\n\n            // Secondary KPIs\n            document.getElementById('val-stock').innerText = fmt(b.stock_value);\n            document.getElementById('val-stock-count').innerText = (data.stock || []).length;\n            const totalExp = (data.expenses || []).reduce((acc, curr) => acc + parseFloat(curr.amount), 0);\n            document.getElementById('val-expenses').innerText = fmt(totalExp);\n            document.getElementById('val-loans').innerText = fmt(b.loans_taken);\n\n            // Lists (Sorted)\n            const recs = [...(data.receivables || [])].sort((a,b) => parseFloat(b.balance) - parseFloat(a.balance));\n            document.getElementById('receivables-list').innerHTML = recs.slice(0, 15).map(item => `\n                <div class=\"list-item\">\n                    <div class=\"item-info\"><p title=\"${item.party}\">${item.party}</p><span>${item.pending_bills} Bills</span></div>\n                    <div class=\"item-value\" style=\"color: var(--accent-green)\">${fmt(item.balance)}</div>\n                </div>\n            `).join('');\n\n            const pays = [...(data.payables || [])].sort((a,b) => parseFloat(b.balance) - parseFloat(a.balance));\n            document.getElementById('payables-list').innerHTML = pays.slice(0, 15).map(item => `\n                <div class=\"list-item\">\n                    <div class=\"item-info\"><p title=\"${item.party}\">${item.party}</p><span>Vendor Account</span></div>\n                    <div class=\"item-value\" style=\"color: var(--accent-red)\">${fmt(item.balance)}</div>\n                </div>\n            `).join('');\n\n            // STABLE Chart Update\n            const accData = data.accounts || [];\n            const labels = accData.map(a => a.name);\n            const values = accData.map(a => parseFloat(a.balance));\n\n            if (charts.liquidity) {\n                if(isChange) {\n                    charts.liquidity.data.labels = labels;\n                    charts.liquidity.data.datasets[0].data = values;\n                    charts.liquidity.update('none'); // Update data without jumping\n                }\n            } else {\n                charts.liquidity = new Chart(document.getElementById('liquidityChart'), {\n                    type: 'doughnut',\n                    data: { labels, datasets: [{ data: values, backgroundColor: ['#fbbf24', '#3b82f6', '#10b981', '#6366f1'], borderWidth: 0 }] },\n                    options: { responsive: true, maintainAspectRatio: false, cutout: '75%', plugins: { legend: { position: 'bottom', labels: { color: '#8b949e', boxWidth: 10, font: { size: 10 } } } } }\n                });\n            }\n        }\n\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000); \n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
    "js": "import React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\n\nconst Button = ({ children, className, ...props }) => (\n  <button className={className} {...props}>\n    {children}\n  </button>\n);\n\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n\n  const handleNext = () => {\n    setCurrentIndex((prevIndex) => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n\n  return (\n    <div className=\"app\">\n      <div className=\"tip-container\">\n        <div className=\"tip-header\">\n          <h2>Custom Widget</h2>\n          <div>{currentIndex + 1} / {appsmith.model.tips.length}</div>\n        </div>\n        <div className=\"content\">{appsmith.model.tips[currentIndex]}</div>\n      </div>\n      <div className=\"button-container\">\n        <Button className=\"primary\" onClick={handleNext}>Next Tip</Button>\n        <Button className=\"reset\" disabled={currentIndex === 0} onClick={handleReset}>Reset</Button>\n      </div>\n    </div>\n  );\n}\n\nappsmith.onReady(() => {\n/*\n\t * This handler function will get called when parent application is ready.\n\t * Initialize your component here\n\t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n\t */\n    ReactDOM.render(<App />, document.getElementById(\"root\"));\n});"
  },
