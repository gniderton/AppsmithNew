    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Executive Forensic Command Center</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        :root {\n            --bg: #05070a; --card: #0f1218; --border: rgba(255, 255, 255, 0.05);\n            --gold: #fbbf24; --green: #10b981; --blue: #3b82f6; --red: #ef4444;\n            --text-main: #ffffff; --text-muted: #94a3b8;\n        }\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }\n        body { background-color: var(--bg); color: var(--text-main); padding: 20px; overflow-x: hidden; }\n\n        /* --- Hero Section --- */\n        .hero { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px; }\n        .hero-title h1 { font-size: 32px; font-weight: 700; letter-spacing: -1px; }\n        .hero-title p { color: var(--text-muted); font-size: 14px; margin-top: 5px; }\n        .net-worth { text-align: right; }\n        .net-worth-label { font-size: 11px; text-transform: uppercase; color: var(--gold); font-weight: 700; letter-spacing: 2px; }\n        .net-worth-val { font-size: 42px; font-weight: 800; color: var(--text-main); line-height: 1; margin-top: 5px; }\n\n        /* --- KPI Row --- */\n        .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px; }\n        .kpi-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; position: relative; }\n        .kpi-card::after { content: ''; position: absolute; bottom: 0; left: 20px; right: 20px; height: 2px; border-radius: 2px; }\n        .kpi-green::after { background: var(--green); }\n        .kpi-red::after { background: var(--red); }\n        .kpi-blue::after { background: var(--blue); }\n        .kpi-gold::after { background: var(--gold); }\n        .kpi-label { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; }\n        .kpi-val { font-size: 24px; font-weight: 700; margin-top: 8px; }\n\n        /* --- Main Layout --- */\n        .main-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 20px; }\n\n        /* --- Visuals Column --- */\n        .chart-container { background: var(--card); border-radius: 16px; border: 1px solid var(--border); padding: 25px; margin-bottom: 20px; }\n        .section-header { font-size: 14px; font-weight: 700; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }\n        .chart-box { height: 220px; position: relative; }\n\n        /* --- Tabs Column --- */\n        .tab-container { background: var(--card); border-radius: 16px; border: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; }\n        .tab-header { display: flex; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); }\n        .tab-btn { padding: 15px 25px; font-size: 13px; font-weight: 600; color: var(--text-muted); cursor: pointer; border-right: 1px solid var(--border); transition: 0.3s; }\n        .tab-btn.active { background: var(--card); color: var(--blue); border-bottom: 2px solid var(--blue); }\n        .tab-btn:hover { background: rgba(255,255,255,0.05); }\n\n        .tab-content { padding: 20px; height: 500px; overflow-y: auto; display: none; }\n        .tab-content.active { display: block; }\n\n        /* --- List Styles --- */\n        .data-table { width: 100%; border-collapse: collapse; }\n        .data-table th { text-align: left; font-size: 11px; color: var(--text-muted); padding: 10px; border-bottom: 1px solid var(--border); text-transform: uppercase; }\n        .data-table td { padding: 12px 10px; font-size: 13px; border-bottom: 1px solid rgba(255,255,255,0.02); }\n        .badge { padding: 3px 8px; border-radius: 6px; font-size: 10px; font-weight: 700; background: rgba(255,255,255,0.05); }\n        .badge-green { color: var(--green); background: rgba(16, 185, 129, 0.1); }\n        .badge-red { color: var(--red); background: rgba(239, 68, 68, 0.1); }\n        \n        .audit-line { display: flex; justify-content: space-between; align-items: center; padding: 10px; border-radius: 8px; background: rgba(255,255,255,0.01); margin-bottom: 8px; font-family: monospace; font-size: 11px; }\n    </style>\n</head>\n<body>\n\n    <div class=\"hero\">\n        <div class=\"hero-title\">\n            <h1>Executive Command Center</h1>\n            <p>Real-time Forensic Liquidity Monitoring • Last Sync: <span id=\"sync-time\">--:--</span></p>\n        </div>\n        <div class=\"net-worth\">\n            <div class=\"net-worth-label\">Total Forensic Capital</div>\n            <div class=\"net-worth-val\" id=\"val-net-worth\">₹0</div>\n        </div>\n    </div>\n\n    <div class=\"kpi-grid\">\n        <div class=\"kpi-card kpi-gold\"><div class=\"kpi-label\">Liquid Assets</div><div class=\"kpi-val\" id=\"val-liquid\">₹0</div></div>\n        <div class=\"kpi-card kpi-red\"><div class=\"kpi-label\">Total Liabilities</div><div class=\"kpi-val\" id=\"val-debt\">₹0</div></div>\n        <div class=\"kpi-card kpi-green\"><div class=\"kpi-label\">Receivables</div><div class=\"kpi-val\" id=\"val-receivables\">₹0</div></div>\n        <div class=\"kpi-card kpi-blue\"><div class=\"kpi-label\">Inventory Worth</div><div class=\"kpi-val\" id=\"val-stock\">₹0</div></div>\n    </div>\n\n    <div class=\"main-grid\">\n        <div class=\"sidebar\">\n            <div class=\"chart-container\">\n                <div class=\"section-header\">Liquidity Allocation</div>\n                <div class=\"chart-box\"><canvas id=\"allocationChart\"></canvas></div>\n            </div>\n            <div class=\"chart-container\">\n                <div class=\"section-header\">Debt Health (Net Worth Ratio)</div>\n                <div class=\"chart-box\"><canvas id=\"healthChart\"></canvas></div>\n            </div>\n        </div>\n\n        <div class=\"tab-container\">\n            <div class=\"tab-header\">\n                <div class=\"tab-btn active\" onclick=\"showTab('tab-audit')\">Bank Audit Streams</div>\n                <div class=\"tab-btn\" onclick=\"showTab('tab-cheques')\">Cheque Inventory</div>\n                <div class=\"tab-btn\" onclick=\"showTab('tab-debtors')\">Debtors & Creditors</div>\n                <div class=\"tab-btn\" onclick=\"showTab('tab-loans')\">Loans & Assets</div>\n            </div>\n\n            <!-- Tab 1: Audit Streams -->\n            <div id=\"tab-audit\" class=\"tab-content active\">\n                <div id=\"audit-list\"></div>\n            </div>\n\n            <!-- Tab 2: Cheques -->\n            <div id=\"tab-cheques\" class=\"tab-content\">\n                <table class=\"data-table\">\n                    <thead><tr><th>Date</th><th>Cheque #</th><th>Bank</th><th>Party</th><th>Amount</th></tr></thead>\n                    <tbody id=\"cheque-body\"></tbody>\n                </table>\n            </div>\n\n            <!-- Tab 3: Debtors & Creditors -->\n            <div id=\"tab-debtors\" class=\"tab-content\">\n                <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 20px;\">\n                    <div>\n                        <div class=\"section-header\" style=\"color: var(--green);\">Top Debtors</div>\n                        <div id=\"debtor-list\"></div>\n                    </div>\n                    <div>\n                        <div class=\"section-header\" style=\"color: var(--red);\">Top Creditors</div>\n                        <div id=\"creditor-list\"></div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Tab 4: Loans & Assets -->\n            <div id=\"tab-loans\" class=\"tab-content\">\n                <div id=\"loans-body\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let charts = {};\n        const fmt = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n\n        function showTab(tabId) {\n            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));\n            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));\n            document.getElementById(tabId).classList.add('active');\n            event.currentTarget.classList.add('active');\n        }\n\n        function update(data) {\n            if (!data || !data.summary) return;\n            const s = data.summary, b = s.breakdown;\n\n            // Hero & KPIs\n            document.getElementById('val-net-worth').innerText = fmt(s.net_capital);\n            document.getElementById('val-liquid').innerText = fmt(b.cash_bank);\n            document.getElementById('val-debt').innerText = fmt(s.total_liabilities);\n            document.getElementById('val-receivables').innerText = fmt(b.receivables);\n            document.getElementById('val-stock').innerText = fmt(b.stock_value);\n            document.getElementById('sync-time').innerText = new Date().toLocaleTimeString();\n\n            // 1. Audit Streams\n            let auditHtml = \"\";\n            Object.entries(data.account_streams || {}).forEach(([acc, stream]) => {\n                auditHtml += `<div style=\"font-size:11px; font-weight:700; color:var(--gold); margin:15px 0 10px;\">${acc}</div>`;\n                stream.forEach(t => {\n                    auditHtml += `\n                        <div class=\"audit-line\">\n                            <span style=\"color:var(--text-muted)\">${t.trans_date}</span>\n                            <span style=\"flex:1; margin: 0 15px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;\">${t.description}</span>\n                            <span style=\"color:${t.amount_in > 0 ? 'var(--green)' : 'var(--red)'}\">${t.amount_in > 0 ? '+' : '-'}${fmt(Math.max(t.amount_in, t.amount_out))}</span>\n                        </div>`;\n                });\n            });\n            document.getElementById('audit-list').innerHTML = auditHtml;\n\n            // 2. Cheques\n            document.getElementById('cheque-body').innerHTML = (data.cheques_list || []).map(c => `\n                <tr><td>${c.cheque_date}</td><td><b>#${c.cheque_number}</b></td><td>${c.bank_name}</td><td>${c.party_name}</td><td style=\"color:var(--blue); font-weight:700;\">${fmt(c.amount)}</td></tr>\n            `).join('');\n\n            // 3. Debtors & Creditors\n            const dRow = (p) => `<div style=\"display:flex; justify-content:space-between; margin-bottom:10px; font-size:12px;\"><span>${p.party}</span><b style=\"color:${p.balance > 0 ? 'inherit' : 'var(--red)'}\">${fmt(p.balance)}</b></div>`;\n            document.getElementById('debtor-list').innerHTML = (data.receivables || []).slice(0,10).map(dRow).join('');\n            document.getElementById('creditor-list').innerHTML = (data.payables || []).slice(0,10).map(dRow).join('');\n\n            // 4. Loans & Assets\n            const lRow = (l, color) => `<div class=\"audit-line\"><span><b>${l.party_name}</b></span><span style=\"color:${color}\">${fmt(l.balance)}</span></div>`;\n            document.getElementById('loans-body').innerHTML = `\n                <div class=\"section-header\">Loans Given</div>${(data.loans_given || []).map(l => lRow(l, 'var(--green)')).join('')}\n                <div style=\"height:20px\"></div>\n                <div class=\"section-header\">Loans Taken</div>${(data.loans_taken || []).map(l => lRow(l, 'var(--red)')).join('')}\n            `;\n\n            // Charts\n            updateAllocationChart(data.accounts);\n            updateHealthChart(s);\n        }\n\n        function updateAllocationChart(accounts) {\n            const ctx = document.getElementById('allocationChart').getContext('2d');\n            if (charts.alloc) { charts.alloc.destroy(); }\n            charts.alloc = new Chart(ctx, {\n                type: 'polarArea',\n                data: {\n                    labels: accounts.map(a => a.name),\n                    datasets: [{\n                        data: accounts.map(a => parseFloat(a.balance)),\n                        backgroundColor: ['rgba(251, 191, 36, 0.5)', 'rgba(59, 130, 246, 0.5)', 'rgba(16, 185, 129, 0.5)', 'rgba(239, 68, 68, 0.5)'],\n                        borderColor: 'transparent'\n                    }]\n                },\n                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { r: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { display: false } } } }\n            });\n        }\n\n        function updateHealthChart(summary) {\n            const ctx = document.getElementById('healthChart').getContext('2d');\n            if (charts.health) { charts.health.destroy(); }\n            charts.health = new Chart(ctx, {\n                type: 'bar',\n                data: {\n                    labels: ['Net Assets', 'Net Debt'],\n                    datasets: [{\n                        data: [summary.total_assets, summary.total_liabilities],\n                        backgroundColor: ['rgba(16, 185, 129, 0.8)', 'rgba(239, 68, 68, 0.8)'],\n                        borderRadius: 10\n                    }]\n                },\n                options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { grid: { display: false }, ticks: { color: '#94a3b8' } } } }\n            });\n        }\n\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
    "js": "function _extends() { return _extends = Object.assign ? Object.assign.bind() : function (n) { for (var e = 1; e < arguments.length; e++) { var t = arguments[e]; for (var r in t) ({}).hasOwnProperty.call(t, r) && (n[r] = t[r]); } return n; }, _extends.apply(null, arguments); }\nimport React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\nconst Button = ({\n  children,\n  className,\n  ...props\n}) => /*#__PURE__*/React.createElement(\"button\", _extends({\n  className: className\n}, props), children);\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n  const handleNext = () => {\n    setCurrentIndex(prevIndex => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"app\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-header\"\n  }, /*#__PURE__*/React.createElement(\"h2\", null, \"Custom Widget\"), /*#__PURE__*/React.createElement(\"div\", null, currentIndex + 1, \" / \", appsmith.model.tips.length)), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"content\"\n  }, appsmith.model.tips[currentIndex])), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"button-container\"\n  }, /*#__PURE__*/React.createElement(Button, {\n    className: \"primary\",\n    onClick: handleNext\n  }, \"Next Tip\"), /*#__PURE__*/React.createElement(Button, {\n    className: \"reset\",\n    disabled: currentIndex === 0,\n    onClick: handleReset\n  }, \"Reset\")));\n}\nappsmith.onReady(() => {\n  /*\n  \t * This handler function will get called when parent application is ready.\n  \t * Initialize your component here\n  \t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n  