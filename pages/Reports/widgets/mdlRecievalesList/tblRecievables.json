  "tableData": "{{\n  RecievablesList.data.filter(item => {\n    // Check DSE filter\n    const dseMatch = SelectDse.selectedOptionValue \n      ? item.dse_name === SelectDse.selectedOptionValue \n      : true;\n    \n    // Check Route filter\n    const routeMatch = SelectRoute.selectedOptionValue \n      ? item.route_name === SelectRoute.selectedOptionValue \n      : true;\n    \n    return dseMatch && routeMatch;\n  })\n}}",
