    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sales Summary Dashboard</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        :root {\n            --bg-main: #0a0c10;\n            --bg-card: #161b22;\n            --text-primary: #f0f6fc;\n            --text-secondary: #8b949e;\n            --accent-sales: #3fb950;\n            --accent-collections: #2188ff;\n            --accent-warning: #d29922;\n            --accent-danger: #f85149;\n            --accent-points: #bf40bf;\n            --border: #30363d;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }\n        body { background-color: var(--bg-main); color: var(--text-primary); padding: 20px; overflow-x: hidden; }\n\n        .dashboard-header { margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }\n        .header-left h1 { font-size: 22px; font-weight: 600; color: #fff; }\n        .header-left p { color: var(--text-secondary); font-size: 13px; margin-top: 4px; }\n\n        .grid-overview { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }\n        .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 18px; transition: all 0.2s ease; position: relative; }\n        .card:hover { transform: translateY(-2px); border-color: #444; }\n        .card-label { color: var(--text-secondary); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }\n        .card-value { font-size: 24px; font-weight: 700; margin-bottom: 6px; }\n        .card-subtext { font-size: 12px; color: var(--text-secondary); margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.05); }\n\n        .grid-main { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px; }\n        @media (max-width: 1100px) { .grid-main { grid-template-columns: 1fr; } }\n\n        .chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; height: 380px; }\n        .section-title { font-size: 14px; font-weight: 600; margin-bottom: 18px; color: #fff; }\n\n        .scroll-list { height: 280px; overflow-y: auto; padding-right: 5px; }\n        .scroll-list::-webkit-scrollbar { width: 4px; }\n        .scroll-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }\n        \n        .list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); }\n        .item-info p { font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }\n        .item-info span { font-size: 11px; color: var(--text-secondary); }\n        .item-value { font-size: 13px; font-weight: 600; }\n\n        .grid-bottom { display: grid; grid-template-columns: 1fr 1fr 1.2fr; gap: 20px; }\n        @media (max-width: 1100px) { .grid-bottom { grid-template-columns: 1fr; } }\n    </style>\n</head>\n<body>\n\n    <div class=\"dashboard-header\">\n        <div class=\"header-left\">\n            <h1>Detailed Sales Summary</h1>\n            <p id=\"period-badge\">Connecting to live data...</p>\n        </div>\n    </div>\n\n    <!-- KPIs -->\n    <div class=\"grid-overview\" id=\"kpi-cards\">\n        <div class=\"card\">\n            <div class=\"card-label\">Gross Sales (Amt)</div>\n            <div class=\"card-value\" style=\"color: var(--accent-sales);\" id=\"kpi-amount\">₹0</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Taxable Value</div>\n            <div class=\"card-value\" id=\"kpi-taxable\">₹0</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Total Tax (GST)</div>\n            <div class=\"card-value\" id=\"kpi-tax\">₹0</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Units Sold (Qty)</div>\n            <div class=\"card-value\" style=\"color: var(--accent-collections);\" id=\"kpi-qty\">0</div>\n        </div>\n        <div class=\"card\">\n            <div class=\"card-label\">Total Lines Billed</div>\n            <div class=\"card-value\" id=\"kpi-lines\">0</div>\n        </div>\n    </div>\n\n    <!-- Main Grid -->\n    <div class=\"grid-main\">\n        <div class=\"chart-container\" style=\"display: flex; flex-direction: column;\">\n            <div class=\"section-title\">Performance by Route & Category</div>\n            <div style=\"display: flex; flex: 1; gap: 20px;\">\n                <div style=\"flex: 2; position: relative;\"><canvas id=\"routeChart\"></canvas></div>\n                <div style=\"flex: 1; position: relative;\"><canvas id=\"categoryChart\"></canvas></div>\n            </div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">Top 10 Customers</div>\n            <div class=\"scroll-list\" id=\"top-customers\"></div>\n        </div>\n    </div>\n\n    <!-- Bottom Grid -->\n    <div class=\"grid-bottom\">\n        <div class=\"card\">\n            <div class=\"section-title\">Sales by Brand</div>\n            <div style=\"height: 250px;\"><canvas id=\"brandChart\"></canvas></div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">DSE Contribution</div>\n            <div style=\"height: 250px;\"><canvas id=\"dseChart\"></canvas></div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">Top 10 Products</div>\n            <div class=\"scroll-list\" id=\"top-products\" style=\"height: 250px;\"></div>\n        </div>\n    </div>\n\n    <script>\n        let charts = {};\n        let lastDataHash = \"\";\n\n        const fCurrency = function(v) { return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v || 0); };\n        const fNumber = function(v) { return new Intl.NumberFormat('en-IN').format(v || 0); };\n\n        function update(data) {\n            if (!data || !data.overall) return;\n\n            // Prevent constant re-animation by checking if data actually changed\n            const currentHash = JSON.stringify(data);\n            if (currentHash === lastDataHash) return;\n            lastDataHash = currentHash;\n\n            // Period\n            const p = data.period || {};\n            let badgeText = p.start + \" to \" + p.end;\n            if (p.fy) {\n                const months = [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\", \"Jul\", \"Aug\", \"Sep\", \"Oct\", \"Nov\", \"Dec\"];\n                badgeText = p.month ? \"FY \" + p.fy + \" • \" + months[p.month - 1] : \"FY \" + p.fy + \" • Full Year\";\n            }\n            document.getElementById('period-badge').innerText = badgeText;\n\n            // KPIs\n            const o = data.overall;\n            document.getElementById('kpi-amount').innerText = fCurrency(o.total_amount);\n            document.getElementById('kpi-taxable').innerText = fCurrency(o.total_taxable);\n            document.getElementById('kpi-tax').innerText = fCurrency(o.total_tax);\n            document.getElementById('kpi-qty').innerText = fNumber(o.total_qty);\n            document.getElementById('kpi-lines').innerText = fNumber(o.total_lines);\n\n            // Lists\n            document.getElementById('top-customers').innerHTML = (data.by_customer || []).map(function(item, idx) {\n                return '<div class=\"list-item\"><div class=\"item-info\"><p title=\"' + item.customer_name + '\">' + (idx + 1) + '. ' + item.customer_name + '</p><span>Qty: ' + fNumber(item.qty) + '</span></div><div class=\"item-value\" style=\"color: var(--text-primary)\">' + fCurrency(item.amount) + '</div></div>';\n            }).join('');\n\n            document.getElementById('top-products').innerHTML = (data.by_product || []).map(function(item, idx) {\n                return '<div class=\"list-item\"><div class=\"item-info\"><p title=\"' + item.product_name + '\">' + (idx + 1) + '. ' + item.product_name + '</p><span>' + item.product_code + '</span></div><div class=\"item-value\" style=\"color: var(--accent-sales)\">' + fCurrency(item.amount) + '</div></div>';\n            }).join('');\n\n            // Chart Colors\n            const colors = {\n                green: '#3fb950',\n                blue: '#2188ff',\n                yellow: '#d29922',\n                red: '#f85149',\n                gray: '#8b949e',\n                purple: '#bf40bf',\n                teal: '#2dd4bf'\n            };\n\n            const gridOptions = { color: '#30363d' };\n            const tickOptions = { color: '#8b949e', font: { family: 'Inter' } };\n\n            // 1. Route Chart\n            if (charts.route) charts.route.destroy();\n            charts.route = new Chart(document.getElementById('routeChart'), {\n                type: 'bar',\n                data: {\n                    labels: (data.by_route || []).map(function(r) { return r.route_name; }),\n                    datasets: [{\n                        label: 'Sales',\n                        data: (data.by_route || []).map(function(r) { return r.amount; }),\n                        backgroundColor: 'rgba(33, 136, 255, 0.7)',\n                        borderColor: colors.blue,\n                        borderWidth: 1,\n                        borderRadius: 4\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    plugins: { legend: { display: false } },\n                    scales: {\n                        x: { grid: { display: false }, ticks: tickOptions },\n                        y: { grid: gridOptions, ticks: Object.assign({}, tickOptions, { callback: function(v) { return '₹' + (v/1000) + 'k'; } }) }\n                    }\n                }\n            });\n\n            // 2. Category Doughnut\n            if (charts.cat) charts.cat.destroy();\n            charts.cat = new Chart(document.getElementById('categoryChart'), {\n                type: 'doughnut',\n                data: {\n                    labels: (data.by_category || []).map(function(c) { return c.category_name; }),\n                    datasets: [{\n                        data: (data.by_category || []).map(function(c) { return c.amount; }),\n                        backgroundColor: [colors.green, colors.blue, colors.yellow, colors.red, colors.purple, colors.teal],\n                        borderWidth: 0\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    cutout: '75%',\n                    plugins: { \n                        legend: { position: 'bottom', labels: { color: colors.gray, boxWidth: 10, font: { family: 'Inter', size: 10 } } }\n                    }\n                }\n            });\n\n            // 3. Brand Chart (Horizontal)\n            const bData = (data.by_brand || []).slice(0, 8);\n            if (charts.brand) charts.brand.destroy();\n            charts.brand = new Chart(document.getElementById('brandChart'), {\n                type: 'bar',\n                data: {\n                    labels: bData.map(function(b) { return b.brand_name; }),\n                    datasets: [{\n                        label: 'Sales',\n                        data: bData.map(function(b) { return b.amount; }),\n                        backgroundColor: 'rgba(63, 185, 80, 0.7)',\n                        borderColor: colors.green,\n                        borderWidth: 1,\n                        borderRadius: 4\n                    }]\n                },\n                options: {\n                    indexAxis: 'y',\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    plugins: { legend: { display: false } },\n                    scales: {\n                        x: { grid: gridOptions, ticks: Object.assign({}, tickOptions, { callback: function(v) { return '₹' + (v/1000) + 'k'; } }) },\n                        y: { grid: { display: false }, ticks: { color: '#f0f6fc', font: { family: 'Inter', size: 11 } } }\n                    }\n                }\n            });\n\n            // 4. DSE Chart (Horizontal)\n            if (charts.dse) charts.dse.destroy();\n            charts.dse = new Chart(document.getElementById('dseChart'), {\n                type: 'bar',\n                data: {\n                    labels: (data.by_dse || []).map(function(d) { return d.dse_name; }),\n                    datasets: [{\n                        label: 'Sales',\n                        data: (data.by_dse || []).map(function(d) { return d.amount; }),\n                        backgroundColor: 'rgba(191, 64, 191, 0.6)',\n                        borderColor: colors.purple,\n                        borderWidth: 1,\n                        borderRadius: 4\n                    }]\n                },\n                options: {\n                    indexAxis: 'y',\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    plugins: { legend: { display: false } },\n                    scales: {\n                        x: { grid: gridOptions, ticks: Object.assign({}, tickOptions, { callback: function(v) { return '₹' + (v/1000) + 'k'; } }) },\n                        y: { grid: { display: false }, ticks: { color: '#f0f6fc', font: { family: 'Inter', size: 11 } } }\n                    }\n                }\n            });\n        }\n\n        const sync = function() { \n            if (window.appsmith && window.appsmith.model && window.appsmith.model.overall) {\n                update(window.appsmith.model); \n            } else if (window.appsmith && window.appsmith.model && window.appsmith.model.data && window.appsmith.model.data.overall) {\n                update(window.appsmith.model.data); \n            }\n        };\n\n        setInterval(sync, 1000);\n        window.onmessage = function(e) { if (e.data && e.data.type === 'UPDATE_MODEL') sync(); };\n        sync();\n    </script>\n</body>\n</html>\n\n",
    "js": "import React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\n\nconst Button = ({ children, className, ...props }) => (\n  <button className={className} {...props}>\n    {children}\n  </button>\n);\n\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n\n  const handleNext = () => {\n    setCurrentIndex((prevIndex) => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n\n  return (\n    <div className=\"app\">\n      <div className=\"tip-container\">\n        <div className=\"tip-header\">\n          <h2>Custom Widget</h2>\n          <div>{currentIndex + 1} / {appsmith.model.tips.length}</div>\n        </div>\n        <div className=\"content\">{appsmith.model.tips[currentIndex]}</div>\n      </div>\n      <div className=\"button-container\">\n        <Button className=\"primary\" onClick={handleNext}>Next Tip</Button>\n        <Button className=\"reset\" disabled={currentIndex === 0} onClick={handleReset}>Reset</Button>\n      </div>\n    </div>\n  );\n}\n\nappsmith.onReady(() => {\n/*\n\t * This handler function will get called when parent application is ready.\n\t * Initialize your component here\n\t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n\t */\n    ReactDOM.render(<App />, document.getElementById(\"root\"));\n});"
  },
  "version": 1,
  "widgetId": "i9ats5vh2z",
  "widgetName": "Custom3"
}