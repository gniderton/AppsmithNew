  "tableData": "{{\n  (() => {\n    const data = getPurchaseLines.data || [];\n    const productMap = {};\n    \n    data.forEach(row => {\n      const prod = row.product_name || \"Unknown Product\";\n      productMap[prod] = (productMap[prod] || 0) + Number(row.net_amount || 0);\n    });\n    \n    return Object.keys(productMap)\n      .map(prod => ({ \n        \"Product Name\": prod, \n        \"Purchase Value\": Number(productMap[prod].toFixed(2)) \n      }))\n      .sort((a, b) => b[\"Purchase Value\"] - a[\"Purchase Value\"])\n      .slice(0, 10);\n  })()\n}}",
