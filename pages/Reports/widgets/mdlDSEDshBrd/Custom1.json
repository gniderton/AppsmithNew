    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>DSE Executive Performance Dashboard</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        :root {\n            --bg-main: #0a0c10;\n            --bg-card: #161b22;\n            --text-primary: #f0f6fc;\n            --text-secondary: #8b949e;\n            --accent-sales: #3fb950;\n            --accent-collections: #2188ff;\n            --accent-warning: #d29922;\n            --accent-danger: #f85149;\n            --accent-points: #bf40bf;\n            --border: #30363d;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }\n        body { background-color: var(--bg-main); color: var(--text-primary); padding: 20px; overflow-x: hidden; }\n\n        .dashboard-header { margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }\n        .header-left h1 { font-size: 22px; font-weight: 600; color: #fff; }\n        .header-left p { color: var(--text-secondary); font-size: 13px; margin-top: 4px; }\n\n        .grid-overview { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px; }\n        .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 18px; transition: all 0.2s ease; position: relative; }\n        .card:hover { transform: translateY(-2px); border-color: #444; }\n        .card-label { color: var(--text-secondary); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }\n        .card-value { font-size: 24px; font-weight: 700; margin-bottom: 6px; }\n        .card-subtext { font-size: 12px; color: var(--text-secondary); margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.05); }\n        .card-subtext b { color: var(--text-primary); }\n\n        .card-delta { font-size: 11px; display: flex; align-items: center; gap: 4px; }\n        .delta-up { color: var(--accent-sales); }\n        .delta-down { color: var(--accent-danger); }\n        .points-glow { color: var(--accent-points); text-shadow: 0 0 10px rgba(191, 64, 191, 0.3); }\n\n        .grid-main { display: grid; grid-template-columns: 2.2fr 1fr; gap: 20px; margin-bottom: 20px; }\n        @media (max-width: 1100px) { .grid-main { grid-template-columns: 1fr; } }\n\n        .chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; height: 380px; }\n        .section-title { font-size: 14px; font-weight: 600; margin-bottom: 18px; color: #fff; display: flex; justify-content: space-between; }\n\n        .scroll-list { max-height: 280px; overflow-y: auto; padding-right: 5px; }\n        .list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); }\n        .item-info p { font-size: 13px; font-weight: 500; }\n        .item-info span { font-size: 11px; color: var(--text-secondary); }\n        .item-value { font-size: 13px; font-weight: 600; }\n\n        .grid-bottom { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 20px; }\n        @media (max-width: 1100px) { .grid-bottom { grid-template-columns: 1fr; } }\n\n        .ageing-bar { display: flex; height: 8px; border-radius: 4px; overflow: hidden; background: #222; margin: 15px 0; }\n        .ageing-seg { height: 100%; }\n        .seg1 { background: var(--accent-sales); }\n        .seg2 { background: var(--accent-warning); }\n        .seg3 { background: var(--accent-danger); }\n\n        .efficiency-pill { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.05); padding: 8px 12px; border-radius: 8px; margin-right: 10px; }\n        .efficiency-pill span { color: var(--text-secondary); font-size: 11px; }\n        .efficiency-pill b { font-size: 13px; }\n    </style>\n</head>\n<body>\n\n    <div class=\"dashboard-header\">\n        <div class=\"header-left\">\n            <h1>Executive Performance Overview</h1>\n            <p id=\"sync-status\">Connecting to live data...</p>\n        </div>\n        <div id=\"productivity-pills\"></div>\n    </div>\n\n    <!-- Monthly & FY KPIs -->\n    <div class=\"grid-overview\" id=\"kpi-cards\">\n        <!-- Injected via JS -->\n    </div>\n\n    <!-- Trend & Customers -->\n    <div class=\"grid-main\">\n        <div class=\"chart-container\">\n            <div class=\"section-title\">Revenue & Collection Trend vs Route Debt</div>\n            <canvas id=\"trendChart\"></canvas>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">Top 10 Customers (Monthly)</div>\n            <div class=\"scroll-list\" id=\"top-customers\"></div>\n        </div>\n    </div>\n\n    <!-- Distributions -->\n    <div class=\"grid-bottom\">\n        <div class=\"card\">\n            <div class=\"section-title\">Brand Sales Mix</div>\n            <div style=\"height: 250px;\"><canvas id=\"brandChart\"></canvas></div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">Overdue Recovery Focus</div>\n            <div class=\"scroll-list\" id=\"overdue-list\"></div>\n        </div>\n        <div class=\"card\">\n            <div class=\"section-title\">Receivables Ageing</div>\n            <div class=\"ageing-bar\" id=\"ageing-bar\"></div>\n            <div id=\"ageing-legend\" style=\"font-size: 11px; line-height: 2.2;\"></div>\n            <div style=\"margin-top: 25px; padding-top: 15px; border-top: 1px solid var(--border);\">\n                <div class=\"card-label\">Market Coverage</div>\n                <div id=\"coverage-val\" style=\"font-size: 24px; font-weight: 700;\">--</div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let charts = {};\n        const f = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n\n        function update(data) {\n            if (!data || !data.metrics) return;\n            const m = data.metrics.month, fy = data.metrics.fy, p = data.productivity || {};\n            \n            let pts = 0, met = 0;\n            (data.daily_trend || []).forEach(d => { if (d.route_receivables > 0 && d.collections >= (d.route_receivables * 0.3)) { pts += 20; met++; } });\n\n            document.getElementById('sync-status').innerText = \"Last Sync: \" + new Date().toLocaleTimeString();\n\n            // Header Pills\n            document.getElementById('productivity-pills').innerHTML = `\n                <div class=\"efficiency-pill\"><span>Goal Met</span><b>${met} Days</b></div>\n                <div class=\"efficiency-pill\"><span>New Customers</span><b>${p.new_customers_this_month || 0}</b></div>\n            `;\n\n            // KPIs\n            const sG = parseFloat(data.metrics.growth_sales_pct);\n            const cG = parseFloat(data.metrics.growth_collection_pct);\n            document.getElementById('kpi-cards').innerHTML = `\n                <div class=\"card\">\n                    <div class=\"card-label\">Sales (Net)</div>\n                    <div class=\"card-value\">${f(m.net_sales_taxable)}</div>\n                    <div class=\"card-delta ${sG >= 0 ? 'delta-up' : 'delta-down'}\">${sG >= 0 ? '↑' : '↓'} ${Math.abs(sG)}% MoM</div>\n                    <div class=\"card-subtext\">FY Total: <b>${f(fy.net_sales_taxable)}</b></div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-label\">Collections</div>\n                    <div class=\"card-value\">${f(m.collection)}</div>\n                    <div class=\"card-delta ${cG >= 0 ? 'delta-up' : 'delta-down'}\">${cG >= 0 ? '↑' : '↓'} ${Math.abs(cG)}% MoM</div>\n                    <div class=\"card-subtext\">FY Total: <b>${f(fy.collection)}</b></div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-label\">Achieved Points</div>\n                    <div class=\"card-value points-glow\">${pts}</div>\n                    <div class=\"card-delta\" style=\"color:var(--accent-points)\">Month Incentive</div>\n                    <div class=\"card-subtext\">Performance Goal: <b>30%</b></div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-label\">Market Coverage</div>\n                    <div class=\"card-value\">${p.market_coverage_pct}%</div>\n                    <div class=\"card-delta delta-up\">Active: ${p.active_customers}</div>\n                    <div class=\"card-subtext\">Assigned: <b>${p.total_assigned_customers}</b></div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-label\">Avg Credit Days</div>\n                    <div class=\"card-value\">${m.avg_credit_days}</div>\n                    <div class=\"card-delta delta-up\">Healthy Pace</div>\n                    <div class=\"card-subtext\">FY Avg: <b>${fy.avg_credit_days}d</b></div>\n                </div>\n            `;\n\n            // Lists & Charts\n            document.getElementById('top-customers').innerHTML = (data.top_customers || []).map((item, idx) => `\n                <div class=\"list-item\"><div class=\"item-info\"><p>${idx + 1}. ${item.customer_name}</p></div><div class=\"item-value\">${f(item.taxable_sales)}</div></div>\n            `).join('');\n\n            document.getElementById('overdue-list').innerHTML = (data.overdue_focus || []).map(item => `\n                <div class=\"list-item\"><div class=\"item-info\"><p>${item.customer_name}</p><span>${item.oldest_invoice_days} days overdue</span></div><div class=\"item-value\" style=\"color: var(--accent-danger)\">${f(item.overdue_amount)}</div></div>\n            `).join('');\n\n            const a = data.ageing || {};\n            const total = (a[\"0-30 Days\"] || 0) + (a[\"31-60 Days\"] || 0) + (a[\"61+ Days\"] || 0);\n            if (total > 0) {\n                document.getElementById('ageing-bar').innerHTML = `\n                    <div class=\"ageing-seg seg1\" style=\"width: ${((a[\"0-30 Days\"]||0)/total*100)}%\"></div>\n                    <div class=\"ageing-seg seg2\" style=\"width: ${((a[\"31-60 Days\"]||0)/total*100)}%\"></div>\n                    <div class=\"ageing-seg seg3\" style=\"width: ${((a[\"61+ Days\"]||0)/total*100)}%\"></div>\n                `;\n            }\n            document.getElementById('ageing-legend').innerHTML = `\n                <div style=\"display:flex; justify-content:space-between\"><span>0-30 Days</span><b>${f(a[\"0-30 Days\"]||0)}</b></div>\n                <div style=\"display:flex; justify-content:space-between\"><span>31-60 Days</span><b>${f(a[\"31-60 Days\"]||0)}</b></div>\n                <div style=\"display:flex; justify-content:space-between\"><span>61+ Days</span><b>${f(a[\"61+ Days\"]||0)}</b></div>\n            `;\n            document.getElementById('coverage-val').innerText = p.market_coverage_pct + \"%\";\n\n            // Charts\n            if (charts.trend) charts.trend.destroy();\n            charts.trend = new Chart(document.getElementById('trendChart'), {\n                type: 'line',\n                data: {\n                    labels: (data.daily_trend || []).map(d => d.label),\n                    datasets: [\n                        { label: 'Sales', data: data.daily_trend.map(d => d.sales), borderColor: '#3fb950', tension: 0.4, fill: true, backgroundColor: 'rgba(63, 185, 80, 0.05)' },\n                        { label: 'Collection', data: data.daily_trend.map(d => d.collections), borderColor: '#2188ff', tension: 0.4 },\n                        { label: 'Route Debt', data: data.daily_trend.map(d => d.route_receivables), borderColor: 'rgba(139,148,158,0.5)', borderDash: [5, 5], tension: 0 }\n                    ]\n                },\n                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#8b949e', font: { size: 10 } } } }, scales: { y: { ticks: { color: '#8b949e', callback: v => '₹' + (v/1000) + 'k' } }, x: { ticks: { color: '#8b949e' } } } }\n            });\n\n            if (charts.brand) charts.brand.destroy();\n            charts.brand = new Chart(document.getElementById('brandChart'), {\n                type: 'bar',\n                data: {\n                    labels: (data.brand_sales || []).map(b => b.brand_name),\n                    datasets: [{ label: 'Sales', data: data.brand_sales.map(b => b.taxable_sales), backgroundColor: 'rgba(33, 136, 255, 0.6)', borderColor: '#2188ff', borderWidth: 1, borderRadius: 4 }]\n                },\n                options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: '#8b949e' } }, y: { ticks: { color: '#fff' } } } }\n            });\n\n            if (charts.cat) charts.cat.destroy();\n            charts.cat = new Chart(document.getElementById('categoryChart'), {\n                type: 'doughnut',\n                data: {\n                    labels: (data.category_sales || []).map(c => c.category_name),\n                    datasets: [{ data: data.category_sales.map(c => c.taxable_sales), backgroundColor: ['#3fb950', '#2188ff', '#d29922', '#f85149', '#8b949e'], borderWidth: 0 }]\n                },\n                options: { responsive: true, maintainAspectRatio: false, cutout: '75%', plugins: { legend: { display: false } } }\n            });\n        }\n\n        const sync = () => { if (window.appsmith && window.appsmith.model && window.appsmith.model.metrics) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
    "js": ""
  },
  "theme": "{{appsmith.theme}}",
