  "searchKey": "",
  "tableData": "{{\n  getBankStatement.data.filter(row => {\n    // 1. Filter by Bank Name\n    const matchesBank = MultiSelectBank.selectedOptionValues.length > 0 \n      ? MultiSelectBank.selectedOptionValues.includes(row.bank_name)\n      : true;\n\n    // 2. Filter by Status\n    const matchesStatus = MultiSelectStatus.selectedOptionValues.length > 0 \n      ? MultiSelectStatus.selectedOptionValues.includes(row.status)\n      : true;\n\n    // 3. Filter by Type (Debit/Credit)\n    const selectedTypes = MultiSelectType.selectedOptionValues;\n    let matchesType = true;\n\n    if (selectedTypes.length > 0) {\n      const isDebit = parseFloat(row.debit_amount) > 0;\n      const isCredit = parseFloat(row.credit_amount) > 0;\n      \n      // Check if the row matches ANY of the selected types\n      matchesType = (selectedTypes.includes(\"debit\") && isDebit) || \n                    (selectedTypes.includes(\"credit\") && isCredit);\n    }\n\n    return matchesBank && matchesStatus && matchesType;\n  })\n}}",
