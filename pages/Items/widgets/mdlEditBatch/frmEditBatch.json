  "scrollContents": true,
  "showReset": true,
  "sourceData": "{{\n  (row => {\n    // 🧮 Enhanced Live Margin Helper (Handles Section Nesting)\n    const calc = (rate) => {\n      // Look for purchase_rate inside the \"Core Pricing\" section of the form\n      const p = Number(frmEditBatch.formData[\"Core Pricing\"]?.purchase_rate || row.purchase_rate);\n      const r = Number(rate);\n      \n      if (!p || p === 0) return \"0.00%\";\n      return (((r - p) / p) * 100).toFixed(2) + \"%\";\n    };\n\n    return {\n      \"Batch Identification\": {\n        \"batch_code\": row.batch_code,\n        \"expiry_date\": row.expiry_date,\n        \"status\": row.status\n      },\n      \"Core Pricing\": {\n        \"mrp\": row.mrp,\n        \"purchase_rate\": row.purchase_rate\n      },\n      \"Selling Rates & Margins\": {\n        \"distributor_rate\": row.distributor_rate,\n        \"distributor_margin_est\": calc(frmEditBatch.formData[\"Selling Rates & Margins\"]?.distributor_rate || row.distributor_rate),\n        \n        \"wholesale_rate\": row.wholesale_rate,\n        \"wholesale_margin_est\": calc(frmEditBatch.formData[\"Selling Rates & Margins\"]?.wholesale_rate || row.wholesale_rate),\n        \n        \"dealer_rate\": row.dealer_rate,\n        \"dealer_margin_est\": calc(frmEditBatch.formData[\"Selling Rates & Margins\"]?.dealer_rate || row.dealer_rate),\n        \n        \"retail_rate\": row.retail_rate,\n        \"retail_margin_est\": calc(frmEditBatch.formData[\"Selling Rates & Margins\"]?.retail_rate || row.retail_rate)\n      }\n    };\n  })(tblBatches.triggeredRow)\n}}\n",
