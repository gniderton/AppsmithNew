  "tableData": "{{\n  getAdjustementHistory.data.data.filter(item => {\n    // If nothing is selected in the Multi-Select, show everything\n    if (CheckboxGroup1.selectedValues.length === 0) return true;\n    \n    // Convert the data's reason to Uppercase to match the Checkbox values\n    return CheckboxGroup1.selectedValues.includes(item.reason.toUpperCase());\n  })\n}}",
