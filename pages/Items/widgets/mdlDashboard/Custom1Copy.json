-card\">\n                <div class=\"section-title\">Price Ladder</div>\n                <div id=\"ui-prices\"></div>\n                \n                <div class=\"section-title\" style=\"margin-top: 30px;\">Stock Cover</div>\n                <div style=\"font-size: 24px; font-weight: 800;\" id=\"ui-cover\">0 <small style=\"color:var(--text-dim)\">Wks</small></div>\n                <p style=\"font-size: 11px; color: var(--text-dim); margin-top: 5px;\">Estimated stock-out date based on 30-day velocity.</p>\n            </div>\n            \n            <div class=\"section-card\">\n                <div class=\"section-title\">Sales Velocity (Monthly Trend)</div>\n                <div style=\"height: 280px;\"><canvas id=\"trendChart\"></canvas></div>\n            </div>\n        </div>\n\n        <div class=\"ledger-box\">\n            <div class=\"tabs\">\n                <button class=\"tab-btn active\" onclick=\"showTab('sales')\">Sales Ledger</button>\n                <button class=\"tab-btn\" onclick=\"showTab('purchase')\">Purchases</button>\n                <button class=\"tab-btn\" onclick=\"showTab('batches')\">Active Batches</button>\n                <button class=\"tab-btn\" onclick=\"showTab('returns')\">Returns</button>\n            </div>\n            <div class=\"tab-content\">\n                <table id=\"ledger-table\"></table>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let chart = null;\n        let globalModel = null;\n\n        function f(v) { return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v); }\n\n        function updateUI(model) {\n            if (!model || !model.product) return;\n            globalModel = model;\n\n            document.getElementById('loading').style.display = 'none';\n            document.getElementById('dashboard').style.display = 'block';\n\n            // Identity\n            document.getElementById('ui-code').innerText = model.product.product_code;\n            document.getElementById('ui-name').innerText = model.product.product_name;\n            document.getElementById('ui-brand').innerText = `${model.product.brand_name} | ${model.product.category_name} | ${model.product.uom}`;\n            document.getElementById('ui-stock').innerText = model.inventory.total_stock;\n\n            // KPIs\n            document.getElementById('ui-sales-val').innerText = f(model.analytics.monthly_value);\n            document.getElementById('ui-margin').innerText = model.analytics.margin_pct + '%';\n            document.getElementById('ui-valuation').innerText = f(model.inventory.valuation);\n            document.getElementById('ui-cover').innerHTML = `${model.inventory.weeks_of_cover} <small style=\"color:var(--text-dim); font-size:14px;\">Wks</small>`;\n\n            // Price Ladder\n            const p = model.product;\n            document.getElementById('ui-prices').innerHTML = `\n                <div class=\"price-step\"><span>Purchase Rate</span><b>${f(p.purchase_rate)}</b></div>\n                <div class=\"price-step\"><span>Distributor</span><b>${f(p.distributor_rate)}</b></div>\n                <div class=\"price-step\"><span>Wholesale</span><b>${f(p.wholesale_rate)}</b></div>\n                <div class=\"price-step\"><span>Dealer</span><b>${f(p.dealer_rate)}</b></div>\n                <div class=\"price-step\" style=\"border:none; color:var(--accent)\"><span>Retail (MRP)</span><b>${f(p.mrp)}</b></div>\n            `;\n\n            showTab('sales'); // Default tab\n            renderChart(model.analytics.trend);\n        }\n\n        function showTab(type) {\n            const btns = document.querySelectorAll('.tab-btn');\n            btns.forEach(b => b.classList.remove('active'));\n            event.target.classList?.add('active');\n\n            const table = document.getElementById('ledger-table');\n            let html = '';\n\n            if (type === 'sales') {\n                html = `<thead><tr><th>Date</th><th>Customer</th><th>Qty</th><th>Rate</th></tr></thead><tbody>` +\n                    globalModel.history.sales.map(s => `<tr><td>${new Date(s.invoice_date).toLocaleDateString()}</td><td>${s.customer_name}</td><td><b>${s.qty}</b></td><td>${f(s.rate)}</td></tr>`).join('') + `</tbody>`;\n            } else if (type === 'purchase') {\n                html = `<thead><tr><th>Date</th><th>Vendor</th><th>Qty</th><th>Rate</th></tr></thead><tbody>` +\n                    globalModel.history.purchases.map(p => `<tr><td>${new Date(p.invoice_date).toLocaleDateString()}</td><td>${p.vendor_name}</td><td><b>${p.qty}</b></td><td>${f(p.rate)}</td></tr>`).join('') + `</tbody>`;\n            } else if (type === 'batches') {\n                html = `<thead><tr><th>Batch</th><th>Qty Remaining</th><th>Expiry</th><th>Status</th></tr></thead><tbody>` +\n                    globalModel.inventory.batches.map(b => `<tr><td><b>${b.batch_code}</b></td><td>${b.quantity_remaining}</td><td>${new Date(b.expiry_date).toLocaleDateString()}</td><td><span class=\"status status-${b.status.toLowerCase()}\">${b.status}</span></td></tr>`).join('') + `</tbody>`;\n            } else if (type === 'returns') {\n                html = `<thead><tr><th>Date</th><th>Customer</th><th>Qty</th><th>Reason</th></tr></thead><tbody>` +\n                    globalModel.history.returns.map(r => `<tr><td>${new Date(r.return_date).toLocaleDateString()}</td><td>${r.customer_name}</td><td style=\"color:var(--danger)\"><b>${r.qty}</b></td><td>${r.reason}</td></tr>`).join('') + `</tbody>`;\n            }\n\n            table.innerHTML = html;\n        }\n\n        function renderChart(trend) {\n            const ctx = document.getElementById('trendChart');\n            if (!ctx) return;\n            if (chart) chart.destroy();\n            chart = new Chart(ctx, {\n                type: 'line',\n                data: {\n                    labels: trend.map(d => d.month),\n                    datasets: [{ \n                        data: trend.map(d => d.qty), \n                        borderColor: '#00d2ff', \n                        borderWidth: 3,\n                        pointRadius: 4,\n                        pointBackgroundColor: '#00d2ff',\n                        tension: 0.4, \n                        fill: true, \n                        backgroundColor: 'rgba(0, 210, 255, 0.05)' \n                    }]\n                },\n                options: { \n                    responsive: true, \n                    maintainAspectRatio: false, \n                    plugins: { legend: { display: false } },\n                    scales: {\n                        y: { grid: { color: 'rgba(255,255,255,0.03)' }, ticks: { color: '#555', font: { size: 10 } } },\n                        x: { grid: { display: false }, ticks: { color: '#555', font: { size: 10 } } }\n                    }\n                }\n            });\n        }\n\n        setInterval(() => {\n            if (window.appsmith && appsmith.model && appsmith.model.product) {\n                if (JSON.stringify(globalModel) !== JSON.stringify(appsmith.model)) {\n                    updateUI(appsmith.model);\n                }\n            }\n        }, 500);\n    </script>\n</body>\n</html>\n",
    "js": ""
  },
