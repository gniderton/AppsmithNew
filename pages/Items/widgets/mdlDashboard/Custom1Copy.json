    "css": "",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <!-- Premium Fonts -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg: #050505;\n            --card: #0f1115;\n            --border: #1f2229;\n            --accent: #00d2ff;\n            --success: #23d160;\n            --danger: #ff3860;\n            --text-dim: #8b949e;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }\n        body { background: var(--bg); color: #fff; padding: 20px; overflow-x: hidden; }\n\n        /* Scrollbar */\n        ::-webkit-scrollbar { width: 4px; }\n        ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }\n\n        #loading { border: 1px solid #333; padding: 60px; text-align: center; border-radius: 20px; background: var(--card); margin-top: 50px; }\n        #dashboard { display: none; max-width: 1200px; margin: 0 auto; }\n\n        /* Header */\n        .hero { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px; }\n        .hero h1 { font-size: 30px; font-weight: 800; letter-spacing: -1px; margin-bottom: 5px; }\n        .hero .code { background: rgba(0, 210, 255, 0.1); color: var(--accent); padding: 4px 12px; border-radius: 6px; font-size: 11px; font-weight: 800; border: 1px solid var(--accent); }\n        \n        .live-stock { text-align: right; }\n        .live-stock .val { font-size: 42px; font-weight: 800; color: var(--accent); line-height: 1; }\n        .live-stock .label { font-size: 10px; font-weight: 800; color: var(--text-dim); margin-top: 8px; letter-spacing: 1px; }\n\n        /* KPI Row */\n        .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }\n        .kpi-card { background: var(--card); border: 1px solid var(--border); padding: 20px; border-radius: 16px; transition: 0.3s; }\n        .kpi-card:hover { border-color: #444; transform: translateY(-3px); }\n        .kpi-label { font-size: 10px; font-weight: 800; color: var(--text-dim); text-transform: uppercase; margin-bottom: 10px; letter-spacing: 1px; }\n        .kpi-val { font-size: 24px; font-weight: 700; }\n\n        /* Main Grid */\n        .grid { display: grid; grid-template-columns: 320px 1fr; gap: 20px; margin-bottom: 24px; }\n        .section-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }\n        .section-title { font-size: 12px; font-weight: 800; color: var(--accent); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1px; display: flex; justify-content: space-between; }\n\n        /* Price Ladder */\n        .price-step { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px dotted #333; }\n        .price-step:last-child { border-bottom: none; }\n        .price-step span { font-size: 13px; color: var(--text-dim); }\n        .price-step b { font-size: 14px; color: #fff; }\n\n        /* Tabs & Tables */\n        .ledger-box { background: var(--card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; margin-top: 20px; }\n        .tabs { display: flex; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); }\n        .tab-btn { padding: 16px 24px; border: none; background: none; color: var(--text-dim); font-size: 12px; font-weight: 700; cursor: pointer; transition: 0.3s; }\n        .tab-btn.active { color: var(--accent); border-bottom: 2px solid var(--accent); background: rgba(0, 210, 255, 0.05); }\n\n        .tab-content { padding: 10px; max-height: 400px; overflow-y: auto; }\n        table { width: 100%; border-collapse: collapse; font-size: 13px; }\n        th { text-align: left; padding: 15px; color: var(--text-dim); font-size: 11px; text-transform: uppercase; border-bottom: 1px solid var(--border); }\n        td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }\n        \n        .status { padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 800; }\n        .status-good { background: rgba(35, 209, 96, 0.1); color: var(--success); }\n        .status-damage { background: rgba(255, 56, 96, 0.1); color: var(--danger); }\n    </style>\n</head>\n<body>\n\n    <div id=\"loading\">\n        <h3>Building Intelligence Console...</h3>\n        <p style=\"color: #666; font-size: 12px; margin-top: 10px;\">Aggregating inventory & sales data</p>\n    </div>\n\n    <div id=\"dashboard\">\n        <header class=\"hero\">\n            <div>\n                <span class=\"code\" id=\"ui-code\">---</span>\n                <h1 id=\"ui-name\">---</h1>\n                <p style=\"color: var(--text-dim); font-size: 13px;\" id=\"ui-brand\">---</p>\n            </div>\n            <div class=\"live-stock\">\n                <div class=\"val\" id=\"ui-stock\">0</div>\n                <div class=\"label\">PHYSICAL STOCK ON HAND</div>\n            </div>\n        </header>\n\n        <div class=\"kpi-row\">\n            <div class=\"kpi-card\"><div class=\"kpi-label\">Month Sales</div><div class=\"kpi-val\" id=\"ui-sales-val\">₹0</div></div>\n            <div class=\"kpi-card\"><div class=\"kpi-label\">Sales Margin</div><div class=\"kpi-val\" id=\"ui-margin\" style=\"color:var(--success)\">0%</div></div>\n            <div class=\"kpi-card\"><div class=\"kpi-label\">Stock Value</div><div class=\"kpi-val\" id=\"ui-valuation\">₹0</div></div>\n            <div class=\"kpi-card\"><div class=\"kpi-label\">Health Index</div><div class=\"kpi-val\" id=\"ui-health\" style=\"color:var(--accent)\">100%</div></div>\n        </div>\n\n        <div class=\"grid\">\n            <div class=\"section-card\">\n                <div class=\"section-title\">Price Ladder</div>\n                <div id=\"ui-prices\"></div>\n                \n                <div class=\"section-title\" style=\"margin-top: 30px;\">Stock Cover</div>\n                <div style=\"font-size: 24px; font-weight: 800;\" id=\"ui-cover\">0 <small style=\"color:var(--text-dim)\">Wks</small></div>\n                <p style=\"font-size: 11px; color: var(--text-dim); margin-top: 5px;\">Estimated stock-out date based on 30-day velocity.</p>\n            </div>\n            \n            <div class=\"section-card\">\n                <div class=\"section-title\">Sales Velocity (Monthly Trend)</div>\n                <div style=\"height: 280px;\"><canvas id=\"trendChart\"></canvas></div>\n            </div>\n        </div>\n\n        <div class=\"ledger-box\">\n            <div class=\"tabs\">\n                <button class=\"tab-btn active\" onclick=\"showTab('sales')\">Sales Ledger</button>\n                <button class=\"tab-btn\" onclick=\"showTab('purchase')\">Purchases</button>\n                <button class=\"tab-btn\" onclick=\"showTab('batches')\">Active Batches</button>\n                <button class=\"tab-btn\" onclick=\"showTab('returns')\">Returns</button>\n            </div>\n            <div class=\"tab-content\">\n                <table id=\"ledger-table\"></table>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let chart = null;\n        let globalModel = null;\n\n        function f(v) { return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v); }\n\n        function updateUI(model) {\n            if (!model || !model.product) return;\n            globalModel = model;\n\n            document.getElementById('loading').style.display = 'none';\n            document.getElementById('dashboard').style.display = 'block';\n\n            // Identity\n            document.getElementById('ui-code').innerText = model.product.product_code;\n            document.getElementById('ui-name').innerText = model.product.product_name;\n            document.getElementById('ui-brand').innerText = `${model.product.brand_name} | ${model.product.category_name} | ${model.product.uom}`;\n            document.getElementById('ui-stock').innerText = model.inventory.total_stock;\n\n            // KPIs\n            document.getElementById('ui-sales-val').innerText = f(model.analytics.monthly_value);\n            document.getElementById('ui-margin').innerText = model.analytics.margin_pct + '%';\n            document.getElementById('ui-valuation').innerText = f(model.inventory.valuation);\n            document.getElementById('ui-cover').innerHTML = `${model.inventory.weeks_of_cover} <small style=\"color:var(--text-dim); font-size:14px;\">Wks</small>`;\n\n            // Price Ladder\n            const p = model.product;\n            document.getElementById('ui-prices').innerHTML = `\n                <div class=\"price-step\"><span>Purchase Rate</span><b>${f(p.purchase_rate)}</b></div>\n                <div class=\"price-step\"><span>Distributor</span><b>${f(p.distributor_rate)}</b></div>\n                <div class=\"price-step\"><span>Wholesale</span><b>${f(p.wholesale_rate)}</b></div>\n                <div class=\"price-step\"><span>Dealer</span><b>${f(p.dealer_rate)}</b></div>\n                <div class=\"price-step\" style=\"border:none; color:var(--accent)\"><span>Retail (MRP)</span><b>${f(p.mrp)}</b></div>\n            `;\n\n            showTab('sales'); // Default tab\n            renderChart(model.analytics.trend);\n        }\n\n        function showTab(type) {\n            const btns = document.querySelectorAll('.tab-btn');\n            btns.forEach(b => b.classList.remove('active'));\n            event.target.classList?.add('active');\n\n            const table = document.getElementById('ledger-table');\n            let html = '';\n\n            if (type === 'sales') {\n                html = `<thead><tr><th>Date</th><th>Customer</th><th>Qty</th><th>Rate</th></tr></thead><tbody>` +\n                    globalModel.history.sales.map(s => `<tr><td>${new Date(s.invoice_date).toLocaleDateString()}</td><td>${s.customer_name}</td><td><b>${s.qty}</b></td><td>${f(s.rate)}</td></tr>`).join('') + `</tbody>`;\n            } else if (type === 'purchase') {\n                html = `<thead><tr><th>Date</th><th>Vendor</th><th>Qty</th><th>Rate</th></tr></thead><tbody>` +\n                    globalModel.history.purchases.map(p => `<tr><td>${new Date(p.invoice_date).toLocaleDateString()}</td><td>${p.vendor_name}</td><td><b>${p.qty}</b></td><td>${f(p.rate)}</td></tr>`).join('') + `</tbody>`;\n            } else if (type === 'batches') {\n                html = `<thead><tr><th>Batch</th><th>Qty Remaining</th><th>Expiry</th><th>Status</th></tr></thead><tbody>` +\n                    globalModel.inventory.batches.map(b => `<tr><td><b>${b.batch_code}</b></td><td>${b.quantity_remaining}</td><td>${new Date(b.expiry_date).toLocaleDateString()}</td><td><span class=\"status status-${b.status.toLowerCase()}\">${b.status}</span></td></tr>`).join('') + `</tbody>`;\n            } else if (type === 'returns') {\n                html = `<thead><tr><th>Date</th><th>Customer</th><th>Qty</th><th>Reason</th></tr></thead><tbody>` +\n                    globalModel.history.returns.map(r => `<tr><td>${new Date(r.return_date).toLocaleDateString()}</td><td>${r.customer_name}</td><td style=\"color:var(--danger)\"><b>${r.qty}</b></td><td>${r.reason}</td></tr>`).join('') + `</tbody>`;\n            }\n\n            table.innerHTML = html;\n        }\n\n        function renderChart(trend) {\n            const ctx = document.getElementById('trendChart');\n            if (!ctx) return;\n            if (chart) chart.destroy();\n            chart = new Chart(ctx, {\n                type: 'line',\n                data: {\n                    labels: trend.map(d => d.month),\n                    datasets: [{ \n                        data: trend.map(d => d.qty), \n                        borderColor: '#00d2ff', \n                        borderWidth: 3,\n                        pointRadius: 4,\n                        pointBackgroundColor: '#00d2ff',\n                        tension: 0.4, \n                        fill: true, \n                        backgroundColor: 'rgba(0, 210, 255, 0.05)' \n                    }]\n                },\n                options: { \n                    responsive: true, \n                    maintainAspectRatio: false, \n                    plugins: { legend: { display: false } },\n                    scales: {\n                        y: { grid: { color: 'rgba(255,255,255,0.03)' }, ticks: { color: '#555', font: { size: 10 } } },\n                        x: { grid: { display: false }, ticks: { color: '#555', font: { size: 10 } } }\n                    }\n                }\n            });\n        }\n\n        setInterval(() => {\n            if (window.appsmith && appsmith.model && appsmith.model.product) {\n                if (JSON.stringify(globalModel) !== JSON.stringify(appsmith.model)) {\n                    updateUI(appsmith.model);\n                }\n            }\n        }, 500);\n    </script>\n</body>\n</html>\n",
    "js": ""
  },
