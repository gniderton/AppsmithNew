  "searchKey": "",
  "tableData": "{{\n  getSalesOrder.data.filter(item => {\n    const selected = CheckboxGroupDse.selectedValues;\n    \n    // If nothing is selected OR \"All\" is in the selection, show everything\n    if (selected.length === 0 || selected.includes(\"All\")) {\n      return true;\n    }\n    \n    // Otherwise, check if the item's DSE name is in the selected list\n    return selected.includes(item.dse_name);\n  })\n}}",
