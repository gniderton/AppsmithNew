    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Employee 360 Dashboard</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        :root {\n            --bg-main: #0d1117;\n            --bg-card: #161b22;\n            --text-primary: #f0f6fc;\n            --text-secondary: #8b949e;\n            --accent-blue: #2f81f7;\n            --accent-green: #3fb950;\n            --accent-red: #f85149;\n            --accent-purple: #8957e5;\n            --border: #30363d;\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }\n        body { background-color: var(--bg-main); color: var(--text-primary); padding: 20px; }\n\n        /* Header Layout */\n        .profile-header { display: flex; align-items: center; gap: 24px; margin-bottom: 30px; background: linear-gradient(135deg, #1c2128 0%, #0d1117 100%); padding: 30px; border-radius: 16px; border: 1px solid var(--border); }\n        .avatar-circle { width: 80px; height: 80px; border-radius: 50%; background: var(--accent-blue); display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700; color: #fff; border: 4px solid #30363d; }\n        .header-info h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }\n        .header-info p { color: var(--text-secondary); font-size: 14px; }\n        .status-pill { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; margin-top: 10px; background: rgba(63, 185, 80, 0.1); color: var(--accent-green); border: 1px solid var(--accent-green); }\n\n        /* KPI Grid */\n        .grid-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }\n        .kpi-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; text-align: center; }\n        .kpi-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin-bottom: 8px; }\n        .kpi-value { font-size: 22px; font-weight: 700; }\n        .kpi-sub { font-size: 11px; color: var(--text-secondary); margin-top: 4px; }\n\n        /* Main Content Layout */\n        .grid-main { display: grid; grid-template-columns: 1.2fr 1fr; gap: 20px; }\n        @media (max-width: 1000px) { .grid-main { grid-template-columns: 1fr; } }\n\n        .section-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 20px; }\n        .section-title { font-size: 14px; font-weight: 600; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; color: #fff; }\n        .section-title i { color: var(--accent-blue); }\n\n        /* Timeline Styles */\n        .timeline { position: relative; padding-left: 30px; }\n        .timeline::before { content: ''; position: absolute; left: 10px; top: 0; bottom: 0; width: 2px; background: var(--border); }\n        .timeline-item { position: relative; margin-bottom: 25px; }\n        .timeline-item::before { content: ''; position: absolute; left: -24px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: var(--accent-blue); border: 2px solid var(--bg-card); }\n        .time-date { font-size: 11px; color: var(--text-secondary); margin-bottom: 4px; }\n        .time-content { font-size: 13px; font-weight: 600; }\n        .time-desc { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }\n\n        /* Info List */\n        .info-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); }\n        .info-row:last-child { border-bottom: none; }\n        .info-label { font-size: 12px; color: var(--text-secondary); }\n        .info-val { font-size: 12px; font-weight: 500; text-align: right; }\n\n        /* Tables */\n        table { width: 100%; border-collapse: collapse; font-size: 12px; }\n        th { text-align: left; padding: 10px; color: var(--text-secondary); font-weight: 500; border-bottom: 1px solid var(--border); }\n        td { padding: 12px 10px; border-bottom: 1px solid var(--border); }\n        .text-green { color: var(--accent-green); font-weight: 600; }\n    </style>\n</head>\n<body>\n\n    <!-- Header -->\n    <div class=\"profile-header\">\n        <div class=\"avatar-circle\" id=\"avatar\">?</div>\n        <div class=\"header-info\">\n            <h1 id=\"full-name\">Loading Profile...</h1>\n            <p id=\"designation-meta\">Designation | Department</p>\n            <div class=\"status-pill\" id=\"status\">ACTIVE</div>\n        </div>\n    </div>\n\n    <!-- KPI Row -->\n    <div class=\"grid-kpis\">\n        <div class=\"kpi-card\">\n            <div class=\"kpi-label\">Current Salary</div>\n            <div class=\"kpi-value\" id=\"curr-salary\">₹ 0</div>\n            <div class=\"kpi-sub\">Last Revision: --</div>\n        </div>\n        <div class=\"kpi-card\">\n            <div class=\"kpi-label\">Loan Balance</div>\n            <div class=\"kpi-value\" style=\"color: var(--accent-purple)\" id=\"loan-bal\">₹ 0</div>\n            <div class=\"kpi-sub\">Active Loans: 0</div>\n        </div>\n        <div class=\"kpi-card\">\n            <div class=\"kpi-label\">Financial Liability</div>\n            <div class=\"kpi-value\" style=\"color: var(--accent-red)\" id=\"pending-liab\">₹ 0</div>\n            <div class=\"kpi-sub\">Advances: ₹ 0</div>\n        </div>\n        <div class=\"kpi-card\">\n            <div class=\"kpi-label\">Attendance Score</div>\n            <div class=\"kpi-value\" style=\"color: var(--accent-green)\" id=\"att-score\">0%</div>\n            <div class=\"kpi-sub\">Last 30 Days</div>\n        </div>\n    </div>\n\n    <!-- Main Content -->\n    <div class=\"grid-main\">\n        <div class=\"left-col\">\n            <div class=\"section-card\">\n                <div class=\"section-title\">Career Progression Timeline</div>\n                <div class=\"timeline\" id=\"timeline-list\">\n                    <!-- Injected via JS -->\n                </div>\n            </div>\n\n            <div class=\"section-card\">\n                <div class=\"section-title\">Recent Salary Disbursements</div>\n                <table>\n                    <thead>\n                        <tr>\n                            <th>Period</th>\n                            <th>Base</th>\n                            <th>Deductions</th>\n                            <th>Net Payout</th>\n                        </tr>\n                    </thead>\n                    <tbody id=\"payment-table\">\n                        <!-- Injected via JS -->\n                    </tbody>\n                </table>\n            </div>\n        </div>\n\n        <div class=\"right-col\">\n            <div class=\"section-card\">\n                <div class=\"section-title\">Contact & Professional Details</div>\n                <div class=\"info-row\"><div class=\"info-label\">Employee Code</div><div class=\"info-val\" id=\"emp-code\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">Joining Date</div><div class=\"info-val\" id=\"join-date\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">Contact Primary</div><div class=\"info-val\" id=\"phone\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">Email Address</div><div class=\"info-val\" id=\"email\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">Aadhar Number</div><div class=\"info-val\" id=\"aadhar\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">License Number</div><div class=\"info-val\" id=\"license\">--</div></div>\n            </div>\n\n            <div class=\"section-card\">\n                <div class=\"section-title\">Banking Information</div>\n                <div class=\"info-row\"><div class=\"info-label\">Bank Name</div><div class=\"info-val\" id=\"bank-name\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">Account No</div><div class=\"info-val\" id=\"acc-no\">--</div></div>\n                <div class=\"info-row\"><div class=\"info-label\">IFSC Code</div><div class=\"info-val\" id=\"ifsc\">--</div></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        const fmt = (v) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);\n        const getMonthName = (m) => [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\", \"Jul\", \"Aug\", \"Sep\", \"Oct\", \"Nov\", \"Dec\"][m - 1];\n\n        function update(data) {\n            if (!data || !data.profile) return;\n            const p = data.profile;\n            const f = data.financials;\n            const c = data.career;\n            const perf = data.performance.attendance_30d;\n\n            // Header\n            document.getElementById('full-name').innerText = p.full_name;\n            document.getElementById('avatar').innerText = p.full_name.charAt(0);\n            document.getElementById('designation-meta').innerText = `${p.designation_name} | ${p.department_name}`;\n            document.getElementById('status').innerText = p.employment_status.toUpperCase();\n            \n            // KPIs\n            document.getElementById('curr-salary').innerText = fmt(p.current_salary);\n            document.getElementById('loan-bal').innerText = fmt(f.total_loan_balance);\n            document.getElementById('pending-liab').innerText = fmt(f.outstanding_liability);\n            \n            const totalDays = Number(perf.present_days) + Number(perf.absent_days);\n            const score = totalDays > 0 ? Math.round((Number(perf.present_days) / totalDays) * 100) : 0;\n            document.getElementById('att-score').innerText = `${score}%`;\n\n            // Contact Info\n            document.getElementById('emp-code').innerText = p.employee_code;\n            document.getElementById('join-date').innerText = new Date(p.joining_date).toLocaleDateString('en-GB');\n            document.getElementById('phone').innerText = p.contact_primary;\n            document.getElementById('email').innerText = p.email;\n            document.getElementById('aadhar').innerText = p.aadhar_no;\n            document.getElementById('license').innerText = p.license_no || 'N/A';\n            document.getElementById('bank-name').innerText = p.bank_name;\n            document.getElementById('acc-no').innerText = p.account_no;\n            document.getElementById('ifsc').innerText = p.ifsc_code;\n\n            // Timeline\n            let timelineHtml = \"\";\n            c.salary_progression.forEach(step => {\n                timelineHtml += `\n                    <div class=\"timeline-item\">\n                        <div class=\"time-date\">${new Date(step.effective_date).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}</div>\n                        <div class=\"time-content\">${fmt(step.new_salary)}</div>\n                        <div class=\"time-desc\">${step.reason}</div>\n                    </div>\n                `;\n            });\n            document.getElementById('timeline-list').innerHTML = timelineHtml;\n\n            // Payment History Table\n            let tableHtml = \"\";\n            c.recent_payments.forEach(pay => {\n                tableHtml += `\n                    <tr>\n                        <td>${getMonthName(pay.month)} ${pay.year}</td>\n                        <td>${fmt(pay.base_salary)}</td>\n                        <td style=\"color:var(--accent-red)\">-${fmt(pay.leave_deduction)}</td>\n                        <td class=\"text-green\">${fmt(pay.net_salary)}</td>\n                    </tr>\n                `;\n            });\n            document.getElementById('payment-table').innerHTML = tableHtml || '<tr><td colspan=\"4\" style=\"text-align:center\">No payments recorded yet</td></tr>';\n        }\n\n        const sync = () => { if (window.appsmith && window.appsmith.model) update(window.appsmith.model); };\n        setInterval(sync, 1000);\n        window.onmessage = (e) => { if (e.data.type === 'UPDATE_MODEL') sync(); };\n    </script>\n</body>\n</html>\n",
