  "onSubmit": "{{\n  apiCreateLiability.run({\n    employee_id: JSONForm1.formData.employee_id,\n    amount: JSONForm1.formData.amount,\n    type: JSONForm1.formData.type,\n    description: JSONForm1.formData.description,\n    invoice_id: JSONForm1.formData.invoice_id || null,\n    user_id: appsmith.user.name // or appsmith.user.id\n  })\n  .then(() => {\n    showAlert('Liability recorded successfully', 'success');\n    \n    // Refresh your lists\n    apiGetEmployeeLiabilities.run(); \n    apiGetSalaryPreview.run(); \n    \n    // Reset form if in a modal\n    resetWidget(\"JSONForm1\");\n    closeModal(\"mdlAddLiability\");\n  })\n  .catch((err) => {\n    showAlert('Error: ' + err.message, 'error');\n  })\n}}\n",
