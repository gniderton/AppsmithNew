  "onSubmit": "{{\n  CreateInstallment.run()\n    .then(() => {\n      // 1. Show a green success popup\n      showAlert('Installment recorded successfully!', 'success');\n      \n      // 2. Refresh the transaction table so the new payment appears\n      getLoanTransactions.run();\n      \n      // 3. Clear the form so it's fresh for the next payment\n      resetWidget('JSONForm_Installment', true);\n      \n      // 4. Close the modal automatically\n      closeModal('ModalEmiEntry');\n    })\n    .catch(() => {\n      // Show a red error popup with the exact message from the backend\n      showAlert('Failed to record installment: ' + CreateInstallment.data.error, 'error');\n    });\n}}",
